{{match part}}{{case helpers}}
    #[cfg(unix)]
    fn process_priority() -> Option<i64> {
        extern "C" {
            fn getpriority(
                which: std::os::raw::c_int,
                who: std::os::raw::c_int,
            ) -> std::os::raw::c_int;
        }

        Some(i64::from(unsafe { getpriority(0, 0) }))
    }

    #[cfg(not(unix))]
    fn process_priority() -> Option<i64> {
        None
    }

    #[cfg(all(unix, target_pointer_width = "64"))]
    fn process_soft_limit(resource: i64) -> Option<i64> {
        #[repr(align(16))]
        struct LimitBuffer([u8; 16]);
        extern "C" {
            fn getrlimit(
                resource: std::os::raw::c_int,
                limits: *mut std::ffi::c_void,
            ) -> std::os::raw::c_int;
        }

        let mut limits = LimitBuffer([0u8; 16]);
        if unsafe { getrlimit(resource as std::os::raw::c_int,
                              limits.0.as_mut_ptr().cast()) } != 0 {
            return None;
        }
        let current = unsafe {
            std::ptr::read_unaligned(limits.0.as_ptr().cast::<u64>())
        };
        Some(current as i64)
    }

    #[cfg(not(all(unix, target_pointer_width = "64")))]
    fn process_soft_limit(_resource: i64) -> Option<i64> {
        None
    }

    #[cfg(unix)]
    fn login_name() -> Option<String> {
        extern "C" {
            fn getlogin_r(
                name: *mut std::os::raw::c_char,
                size: usize,
            ) -> std::os::raw::c_int;
        }

        let mut buffer = [0u8; 256];
        if unsafe { getlogin_r(buffer.as_mut_ptr().cast(), buffer.len()) } != 0 {
            return None;
        }
        let end = buffer.iter().position(|byte| *byte == 0)?;
        Some(String::from_utf8_lossy(&buffer[..end]).into_owned())
    }

    #[cfg(not(unix))]
    fn login_name() -> Option<String> {
        None
    }
