{{match part}}{{case helpers}}
    #[cfg(unix)]
    fn random_unit_value() -> Option<f64> {
        extern "C" {
            fn drand48() -> std::os::raw::c_double;
        }

        Some(unsafe { drand48() })
    }

    #[cfg(not(unix))]
    fn random_unit_value() -> Option<f64> {
        None
    }

    #[cfg(unix)]
    fn random_between_value(low: i64, high: i64) -> Option<i64> {
        extern "C" {
            fn lrand48() -> std::os::raw::c_long;
        }

        if low > high {
            return None;
        }
        let range = i128::from(high) - i128::from(low) + 1;
        let draw = i128::from(unsafe { lrand48() });
        Some((i128::from(low) + draw.rem_euclid(range)) as i64)
    }

    #[cfg(not(unix))]
    fn random_between_value(_low: i64, _high: i64) -> Option<i64> {
        None
    }

    #[cfg(unix)]
    fn seed_random_value(seed: i64) -> bool {
        extern "C" {
            fn srand48(seed: std::os::raw::c_long);
        }

        unsafe { srand48(seed as std::os::raw::c_long) };
        true
    }

    #[cfg(not(unix))]
    fn seed_random_value(_seed: i64) -> bool {
        false
    }
{{case arms}}
            "random/1" => {
                let random = match Self::random_unit_value() {
                    Some(random) => Value::Float(random),
                    None => return false,
                };
                let output = self.get_reg_raw("A1").unwrap_or(Value::Uninit);
                let mark = self.trail.len();
                if self.unify(&output, &random) {
                    self.pc += 1; true
                } else {
                    self.unwind_trail_to(mark);
                    false
                }
            }
            "random_between/3" => {
                let low = match self.get_reg_raw("A1")
