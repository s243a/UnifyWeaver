                    Some(Value::Integer(low)) => low,
                    _ => return false,
                };
                let high = match self.get_reg_raw("A2")
                    .map(|v| self.deref_heap(&self.deref_var(&v))) {
                    Some(Value::Integer(high)) => high,
                    _ => return false,
                };
                let random = match Self::random_between_value(low, high) {
                    Some(random) => Value::Integer(random),
                    None => return false,
                };
                let output = self.get_reg_raw("A3").unwrap_or(Value::Uninit);
                let mark = self.trail.len();
                if self.unify(&output, &random) {
                    self.pc += 1; true
                } else {
                    self.unwind_trail_to(mark);
                    false
                }
            }
            "set_random/1" => {
                let option = match self.get_reg_raw("A1")
                    .map(|v| self.deref_heap(&self.deref_var(&v))) {
                    Some(option) => option,
                    None => return false,
                };
                let seed = match option {
                    Value::Str(functor, args)
                        if args.len() == 1
                            && Self::display_functor_name(&functor, 1) == "seed" =>
                    {
                        match self.deref_heap(&self.deref_var(&args[0])) {
                            Value::Integer(seed) => seed,
                            _ => return false,
                        }
                    }
                    _ => return false,
                };
                if Self::seed_random_value(seed) {
                    self.pc += 1; true
                } else {
                    false
                }
            }
