// CSR (Compressed Sparse Row) reverse-index reader for category_child.
//
// Reads the binary artifact produced by build_reverse_csr_artifact.py
// (format unifyweaver.reverse_csr.v1):
//   <rel>.csr.idx   int32_le key, uint64_le offset_edges, uint32_le count
//                   (16 bytes/record, key-sorted)
//   <rel>.csr.val   int32_le values (4 bytes each, contiguous per key)
//   <rel>.csr.meta  JSON manifest
//
// Implements state::LookupSource so it plugs into the lazy_lookups
// ecosystem: register under "category_child/2" and the bidirectional
// kernel child accessor picks it up via resolve_edge_accessor (which
// prefers a lazy source over the eager reverse-derived table). The
// kernel-side intern-id <-> raw-id translation is the same machinery
// the LMDB lazy path uses (build_lazy_int_maps / int_native_edges).
//
// Index backend: sorted_array (binary search over the in-memory index,
// 16 bytes per key — ~24 MB even at enwiki scale). The lmdb_offset
// backend is rejected explicitly; port it from the C target
// (wam_reverse_csr_load_lmdb_offset*) if O(1) key lookup is needed.
// Mirrors the F# reader (csr_reader.fs.mustache): index in memory,
// values via positioned read on a shared handle.

use std::fs;
use std::fs::File;
use std::io::{Read, Seek, SeekFrom};
use std::path::Path;
use std::sync::Mutex;

use crate::state::LookupSource;

pub struct CsrLookupSource {
    /// (key, offset_edges, count) records, key-sorted — binary searched.
    idx: Vec<(i32, u64, u32)>,
    /// Values file; Mutex-serialised seek+read keeps the reader portable
    /// (the F# reader locks the same way). Reads are count*4 bytes at
    /// offset_edges*4.
    val: Mutex<File>,
    pub parent_count: usize,
    pub edge_count: usize,
}

/// Extract a string field from the machine-written manifest. Minimal by
/// design: build_reverse_csr_artifact.py emits plain unescaped string
/// values, so this is NOT a general JSON parser. Returns None for
/// missing keys and for non-string values (e.g. null).
fn manifest_str_field(text: &str, key: &str) -> Option<String> {
    let needle = format!("\"{}\":", key);
    let start = text.find(&needle)? + needle.len();
    let rest = text[start..].trim_start();
    if !rest.starts_with('"') {
        return None;
    }
    let inner = &rest[1..];
    let end = inner.find('"')?;
    Some(inner[..end].to_string())
}

fn manifest_usize_field(text: &str, key: &str) -> Option<usize> {
    let needle = format!("\"{}\":", key);
    let start = text.find(&needle)? + needle.len();
    let rest = text[start..].trim_start();
    let end = rest
        .find(|c: char| !c.is_ascii_digit())
        .unwrap_or(rest.len());
    rest[..end].parse().ok()
}

impl CsrLookupSource {
    /// Open `<artifact_dir>/<relation>.csr.{meta,idx,val}`. The usual
    /// relation for the bidirectional kernel child direction is
    /// "category_child".
    pub fn open(artifact_dir: &str, relation: &str) -> Result<Self, String> {
        let dir = Path::new(artifact_dir);
        let meta_path = dir.join(format!("{}.csr.meta", relation));
        let meta = fs::read_to_string(&meta_path)
            .map_err(|e| format!("CSR manifest read failed ({}): {}", meta_path.display(), e))?;
        let fmt = manifest_str_field(&meta, "format").unwrap_or_default();
        if fmt != "unifyweaver.reverse_csr.v1" {
            return Err(format!("unsupported CSR format: {}", fmt));
        }
        let enc = manifest_str_field(&meta, "id_encoding").unwrap_or_default();
        if enc != "int32_le" {
            return Err(format!("unsupported CSR id_encoding: {}", enc));
        }
        let backend = manifest_str_field(&meta, "index_backend")
            .unwrap_or_else(|| "sorted_array".to_string());
        if backend != "sorted_array" {
            return Err(format!(
                "unsupported CSR index_backend: {} (this reader supports sorted_array)",
                backend
            ));
        }
        let idx_name = manifest_str_field(&meta, "index_path")
            .unwrap_or_else(|| format!("{}.csr.idx", relation));
        let val_name = manifest_str_field(&meta, "values_path")
            .unwrap_or_else(|| format!("{}.csr.val", relation));
        let idx_bytes = fs::read(dir.join(&idx_name))
            .map_err(|e| format!("CSR index read failed ({}): {}", idx_name, e))?;
        if idx_bytes.len() % 16 != 0 {
            return Err(format!(
                "CSR index size {} is not a multiple of the 16-byte record size",
                idx_bytes.len()
            ));
        }
        let mut idx = Vec::with_capacity(idx_bytes.len() / 16);
        for rec in idx_bytes.chunks_exact(16) {
            let key = i32::from_le_bytes([rec[0], rec[1], rec[2], rec[3]]);
            let offset = u64::from_le_bytes([
                rec[4], rec[5], rec[6], rec[7], rec[8], rec[9], rec[10], rec[11],
            ]);
            let count = u32::from_le_bytes([rec[12], rec[13], rec[14], rec[15]]);
            idx.push((key, offset, count));
        }
        let val = File::open(dir.join(&val_name))
            .map_err(|e| format!("CSR values open failed ({}): {}", val_name, e))?;
        let parent_count = manifest_usize_field(&meta, "parent_count").unwrap_or(idx.len());
        let edge_count = manifest_usize_field(&meta, "edge_count").unwrap_or(0);
        Ok(CsrLookupSource {
            idx,
            val: Mutex::new(val),
            parent_count,
            edge_count,
        })
    }

    fn offset_count(&self, key: i32) -> Option<(u64, u32)> {
        self.idx
            .binary_search_by_key(&key, |r| r.0)
            .ok()
            .map(|i| (self.idx[i].1, self.idx[i].2))
    }

    /// All keys present in the index (sorted).
    pub fn keys(&self) -> Vec<i32> {
        self.idx.iter().map(|r| r.0).collect()
    }
}

impl LookupSource for CsrLookupSource {
    fn lookup_key_for_atom(&self, atom: &str) -> Option<i32> {
        // CSR artifacts live in the raw int-id space; atoms are the
        // decimal id strings (mirrors the int-native LMDB path).
        atom.parse().ok()
    }

    fn lookup_parents(&self, key: i32) -> Vec<i32> {
        // For a category_child artifact this returns the CHILDREN of
        // key — "parents" is the trait name for the value side of
        // whatever relation the source serves.
        let (offset, count) = match self.offset_count(key) {
            Some(oc) => oc,
            None => return Vec::new(),
        };
        if count == 0 {
            return Vec::new();
        }
        let mut buf = vec![0u8; count as usize * 4];
        {
            let mut f = self.val.lock().unwrap();
            if f.seek(SeekFrom::Start(offset * 4)).is_err() {
                return Vec::new();
            }
            if f.read_exact(&mut buf).is_err() {
                return Vec::new();
            }
        }
        buf.chunks_exact(4)
            .map(|b| i32::from_le_bytes([b[0], b[1], b[2], b[3]]))
            .collect()
    }

    fn atom_for_key(&self, key: i32) -> Option<String> {
        Some(key.to_string())
    }
}
