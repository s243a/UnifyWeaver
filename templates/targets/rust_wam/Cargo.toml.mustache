[package]
name = "{{module_name}}"
version = "0.1.0"
edition = "2021"
description = "Generated by UnifyWeaver WAM-to-Rust transpilation"

[[bin]]
name = "bench"
path = "src/main.rs"

[lib]
name = "wam_lib"
path = "src/lib.rs"

[dependencies]
rayon = { version = "1", optional = true }
{{#use_lmdb_zero}}
lmdb-zero = "0.4"
{{/use_lmdb_zero}}
{{#use_heed}}
heed = "0.20"
{{/use_heed}}

[features]
parallel = ["rayon"]
