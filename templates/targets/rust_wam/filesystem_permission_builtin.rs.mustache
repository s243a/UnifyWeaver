    #[cfg(unix)]
    fn filesystem_access(path: &str, mode: i64) -> bool {
        extern "C" {
            fn access(
                path: *const std::os::raw::c_char,
                mode: std::os::raw::c_int,
            ) -> std::os::raw::c_int;
        }

        let path = match std::ffi::CString::new(path) {
            Ok(path) => path,
            Err(_) => return false,
        };
        unsafe { access(path.as_ptr(), mode as std::os::raw::c_int) == 0 }
    }

    #[cfg(not(unix))]
    fn filesystem_access(_path: &str, _mode: i64) -> bool {
        false
    }

