{{match part}}{{case helpers}}
    fn current_working_directory() -> Option<String> {
        std::env::current_dir()
            .ok()
            .map(|path| path.to_string_lossy().into_owned())
    }

    fn change_working_directory(path: &str) -> bool {
        std::env::set_current_dir(path).is_ok()
    }

    #[cfg(unix)]
    fn set_file_creation_mask(mask: i64) -> Option<i64> {
        extern "C" {
            fn umask(mask: std::os::raw::c_uint) -> std::os::raw::c_uint;
        }

        Some(i64::from(unsafe { umask(mask as std::os::raw::c_uint) }))
    }

    #[cfg(not(unix))]
    fn set_file_creation_mask(_mask: i64) -> Option<i64> {
        None
    }
