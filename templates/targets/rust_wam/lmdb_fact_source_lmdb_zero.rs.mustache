// LMDB-backed edge lookup for the wam-rust runtime.
//
// Mirrors the Haskell side's lmdb_fact_source for the Phase 1 sub-db layout:
//
//   s2i              (string  -> int32)   intern table forward
//   i2s              (int32   -> string)  intern table reverse
//   category_parent  (int32 child  -> int32 parent)   DUPSORT
//   category_child   (int32 parent -> int32 child)    DUPSORT (reverse edges)
//
// LMDB constraints respected:
//   - sub-db handles (Database<'static>) are opened ONCE in the parent
//     thread; concurrent Database::open is racy.  Validated empirically
//     against the 1k_cats fixture in 2026-05 lmdb-zero parallelism eval.
//   - Read transactions and cursors are per-thread.  Each lookup opens
//     its own short-lived ReadTransaction (R3 cache work later memoises
//     hot keys; for R1 we just open/close per lookup).
//   - Environment is shared via Arc<Environment>; lmdb-zero Environment
//     is Sync so &Environment is Send.
//
// Endianness: int32 keys/values are stored little-endian, matching the
// streaming ingest pipeline (examples/streaming/lmdb_ingest.py) and the
// Phase 1 converter (examples/benchmark/convert_lmdb_to_phase1_layout.py).

use std::collections::HashMap;
use std::sync::Arc;

use lmdb_zero as lmdb;

/// Holds the LMDB environment plus pre-opened sub-database handles.
/// Cheap to clone (Arc bumps under the hood).
#[derive(Clone)]
pub struct LmdbFactSource {
    pub env: Arc<lmdb::Environment>,
    pub s2i: Arc<lmdb::Database<'static>>,
    pub i2s: Arc<lmdb::Database<'static>>,
    pub category_parent: Arc<lmdb::Database<'static>>,
    pub category_child: Arc<lmdb::Database<'static>>,
}

impl LmdbFactSource {
    /// Open the Phase 1 LMDB layout at `lmdb_path`.
    /// Sub-db handles are opened in the calling thread.
    pub fn open(lmdb_path: &str) -> Result<Self, lmdb::Error> {
        let env = unsafe {
            let mut builder = lmdb::EnvBuilder::new()?;
            builder.set_maxdbs(16)?;
            builder.open(lmdb_path, lmdb::open::Flags::empty(), 0o600)?
        };
        let env = Arc::new(env);

        let open_dup = |name: &str| -> Result<Arc<lmdb::Database<'static>>, lmdb::Error> {
            let db = lmdb::Database::open(
                Arc::clone(&env),
                Some(name),
                &lmdb::DatabaseOptions::new(lmdb::db::DUPSORT),
            )?;
            Ok(Arc::new(db))
        };

        Ok(LmdbFactSource {
            s2i: open_dup("s2i")?,
            i2s: open_dup("i2s")?,
            category_parent: open_dup("category_parent")?,
            category_child: open_dup("category_child")?,
            env,
        })
    }

    /// Read the s2i intern table into a HashMap.  Used once at startup
    /// when resolving string seeds/roots to int IDs.
    pub fn load_s2i(&self) -> Result<HashMap<String, i32>, lmdb::Error> {
        let txn = lmdb::ReadTransaction::new(&*self.env)?;
        let access = txn.access();
        let mut cursor = txn.cursor(&*self.s2i)?;
        let mut out = HashMap::new();
        match cursor.first::<[u8], [u8]>(&access) {
            Ok((k, v)) => {
                out.insert(decode_string(k), decode_i32(v));
                while let Ok((k, v)) = cursor.next::<[u8], [u8]>(&access) {
                    out.insert(decode_string(k), decode_i32(v));
                }
            }
            Err(lmdb::Error::Code(lmdb_zero::error::NOTFOUND)) => {}
            Err(e) => return Err(e),
        }
        Ok(out)
    }

    /// Read the i2s reverse intern table.  Used for output rendering.
    pub fn load_i2s(&self) -> Result<HashMap<i32, String>, lmdb::Error> {
        let txn = lmdb::ReadTransaction::new(&*self.env)?;
        let access = txn.access();
        let mut cursor = txn.cursor(&*self.i2s)?;
        let mut out = HashMap::new();
        match cursor.first::<[u8], [u8]>(&access) {
            Ok((k, v)) => {
                out.insert(decode_i32(k), decode_string(v));
                while let Ok((k, v)) = cursor.next::<[u8], [u8]>(&access) {
                    out.insert(decode_i32(k), decode_string(v));
                }
            }
            Err(lmdb::Error::Code(lmdb_zero::error::NOTFOUND)) => {}
            Err(e) => return Err(e),
        }
        Ok(out)
    }

    /// Look up all parents of `child_id` via cursor MDB_SET + MDB_NEXT_DUP.
    /// Returns an empty Vec if the key is absent.
    pub fn lookup_parents(&self, child_id: i32) -> Result<Vec<i32>, lmdb::Error> {
        self.lookup_via_dupsort(&self.category_parent, child_id)
    }

    /// Look up all children of `parent_id` (reverse-edge sub-db).
    pub fn lookup_children(&self, parent_id: i32) -> Result<Vec<i32>, lmdb::Error> {
        self.lookup_via_dupsort(&self.category_child, parent_id)
    }

    fn lookup_via_dupsort(
        &self,
        db: &lmdb::Database<'static>,
        key_id: i32,
    ) -> Result<Vec<i32>, lmdb::Error> {
        let txn = lmdb::ReadTransaction::new(&*self.env)?;
        let access = txn.access();
        let mut cursor = txn.cursor(db)?;
        let key_bytes = key_id.to_le_bytes();

        let mut out = Vec::new();
        match cursor.seek_k::<[u8], [u8]>(&access, &key_bytes) {
            Ok(_) => {
                // seek_k positions at first dup for key; iterate all dups.
                let v = cursor.get_current::<[u8], [u8]>(&access)?.1;
                out.push(decode_i32(v));
                while let Ok((_, v)) = cursor.next_dup::<[u8], [u8]>(&access) {
                    out.push(decode_i32(v));
                }
            }
            Err(lmdb::Error::Code(lmdb_zero::error::NOTFOUND)) => {}
            Err(e) => return Err(e),
        }
        Ok(out)
    }
}

fn decode_i32(bytes: &[u8]) -> i32 {
    // Phase 1 layout stores int32 values little-endian.
    let mut buf = [0u8; 4];
    let len = bytes.len().min(4);
    buf[..len].copy_from_slice(&bytes[..len]);
    i32::from_le_bytes(buf)
}

fn decode_string(bytes: &[u8]) -> String {
    // s2i / i2s store UTF-8 strings.  Lossy decode keeps us robust to
    // any non-UTF-8 byte sequences that may have slipped through ingest.
    String::from_utf8_lossy(bytes).into_owned()
}
