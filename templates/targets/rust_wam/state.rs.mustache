            format!("cache_attr_l1_hits={}", l1),
            format!("cache_attr_l2_hits={}", l2),
            format!("cache_attr_misses={}", miss),
            format!("cache_attr_hit_rate={:.4}", hit_rate),
            format!("cache_attr_inner_lookup_ms={:.3}", inner_ns as f64 / 1.0e6),
