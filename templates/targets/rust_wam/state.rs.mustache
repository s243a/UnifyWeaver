pub struct CacheAttribution {
    /// Served from the per-thread L1 cache (lock-free).
    pub l1_hits: AtomicU64,
    /// Served from the shared sharded L2 cache.
    pub l2_hits: AtomicU64,
    /// Fell through both tiers to the inner source.
