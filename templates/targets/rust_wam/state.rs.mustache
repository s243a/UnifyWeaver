    pub fn register_indexed_weighted_edge_triples(&mut self, pred: &str, triples: &[(&str, &str, f64)]) {
        let mut index: HashMap<String, Vec<(String, f64)>> = HashMap::new();
        for (from, to, weight) in triples {
            index.entry((*from).to_string())
                .or_insert_with(Vec::new)
                .push(((*to).to_string(), *weight));
        }
        self.indexed_weighted_edge.insert(pred.to_string(), index);
    }

