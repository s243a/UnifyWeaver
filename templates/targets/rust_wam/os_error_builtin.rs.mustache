{{match part}}{{case helpers}}
    fn current_os_error_code() -> i64 {
        std::io::Error::last_os_error()
            .raw_os_error()
            .map(i64::from)
            .unwrap_or(0)
    }

    #[cfg(unix)]
    fn os_error_message(code: i64) -> Option<String> {
        extern "C" {
            fn strerror(
                error: std::os::raw::c_int,
            ) -> *const std::os::raw::c_char;
        }

        let message = unsafe { strerror(code as std::os::raw::c_int) };
        if message.is_null() {
            return None;
        }
        Some(unsafe { std::ffi::CStr::from_ptr(message) }
            .to_string_lossy()
            .into_owned())
    }

    #[cfg(not(unix))]
    fn os_error_message(code: i64) -> Option<String> {
        Some(std::io::Error::from_raw_os_error(code as i32).to_string())
    }
