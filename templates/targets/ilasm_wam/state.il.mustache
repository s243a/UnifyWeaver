// === WAM State Management Methods ===

// Constructor: create WamState with code and labels
.method public instance void .ctor(class Instruction[] code, int32[] labels) cil managed {
    .maxstack 4
    ldarg.0
    call instance void [mscorlib]System.Object::.ctor()
    // PC = 0
    ldarg.0
    ldc.i4.0
    stfld int32 WamState::PC
    // Regs = new Value[32]
    ldarg.0
    ldc.i4 32
    newarr Value
    stfld class Value[] WamState::Regs
    // Initialize all regs to UnboundValue
    ldc.i4.0
    stloc.0
L_init_regs:
    ldloc.0
    ldc.i4 32
    bge L_init_done
    ldarg.0
    ldfld class Value[] WamState::Regs
    ldloc.0
    ldloc.0
    call string [mscorlib]System.Convert::ToString(int32)
    newobj instance void UnboundValue::.ctor(string)
    stelem.ref
    ldloc.0
    ldc.i4.1
    add
    stloc.0
    br L_init_regs
L_init_done:
    // Stack = new List<StackEntry>()
    ldarg.0
    newobj instance void class [mscorlib]System.Collections.Generic.List`1<class StackEntry>::.ctor()
    stfld class [mscorlib]System.Collections.Generic.List`1<class StackEntry> WamState::Stack
    // Heap = new Value[4096]
    ldarg.0
    ldc.i4 4096
    newarr Value
    stfld class Value[] WamState::Heap
    ldarg.0
    ldc.i4.0
    stfld int32 WamState::HeapSize
    // Trail = new List<TrailEntry>()
    ldarg.0
    newobj instance void class [mscorlib]System.Collections.Generic.List`1<class TrailEntry>::.ctor()
    stfld class [mscorlib]System.Collections.Generic.List`1<class TrailEntry> WamState::Trail
    // CP = 0
    ldarg.0
    ldc.i4.0
    stfld int32 WamState::CP
    // ChoicePoints = new List<ChoicePoint>()
    ldarg.0
    newobj instance void class [mscorlib]System.Collections.Generic.List`1<class ChoicePoint>::.ctor()
    stfld class [mscorlib]System.Collections.Generic.List`1<class ChoicePoint> WamState::ChoicePoints
    // Code and Labels
    ldarg.0
    ldarg.1
    stfld class Instruction[] WamState::Code
    ldarg.0
    ldarg.1
    ldlen
    conv.i4
    stfld int32 WamState::CodeLength
    ldarg.0
    ldarg.2
    stfld int32[] WamState::Labels
    ldarg.0
    ldarg.2
    ldlen
    conv.i4
    stfld int32 WamState::LabelCount
    // Halted = false
    ldarg.0
    ldc.i4.0
    stfld bool WamState::Halted
    ret
    .locals init (int32 v0)
}

