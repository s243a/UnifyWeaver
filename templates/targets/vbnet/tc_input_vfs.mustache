

    Public Shared Sub Main(args As String())
        Dim query As New {{pred_cap}}Query()

        ' Read {{base}} facts from notebook cell: {{vfs_source}}
        For Each line As String In System.IO.File.ReadLines("{{vfs_source}}")
            If line.Contains(":") Then
                Dim parts() As String = line.Split(":"c, 2)
                query.AddFact(parts(0).Trim(), parts(1).Trim())
            End If
        Next
