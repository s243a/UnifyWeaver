package {{package}}

// Generated by UnifyWeaver Kotlin Hybrid WAM target.
// This runtime intentionally starts small but executable: it provides the
// stable ABI used by generated predicate registrars and a deterministic core
// instruction subset for facts, constants, variables, equality, simple calls,
// and first-order compound/list term construction and matching.  Rich
// choicepoint/indexing semantics are added incrementally without changing
// registrar output.

sealed class Value {
    data class Atom(val name: String) : Value()
    data class IntVal(val value: Long) : Value()
    data class FloatVal(val value: Double) : Value()
    data class Var(val name: String) : Value()
    data class Ref(val address: Int) : Value()
    data class Struct(val functor: String, val args: List<Value?>) : Value()
    data class ListVal(val items: List<Value>) : Value()
}

data class Instruction(val op: String, val args: List<Any?> = emptyList())

data class ChoicePoint(
    val pc: Int,
    val registers: MutableMap<String, Value?>,
    val trailSize: Int,
)

sealed class WamContext {
    data class Read(val args: List<Value?>, var index: Int = 0) : WamContext()
    data class Write(
        val targetRegister: String,
        val functor: String,
        val arity: Int,
        val args: MutableList<Value?> = mutableListOf(),
    ) : WamContext()
}

class WamState(
    var pc: Int = 0,
    val registers: MutableMap<String, Value?> = linkedMapOf(),
    val heap: MutableList<Value?> = mutableListOf(),
    val trail: MutableList<String> = mutableListOf(),
    val choicePoints: MutableList<ChoicePoint> = mutableListOf(),
    var context: WamContext? = null,
) {
    fun deref(value: Value?): Value? = when (value) {
        is Value.Var -> {
            val bound = registers[value.name]
            if (bound == null || bound == value) value else deref(bound)
        }
        else -> value
    }

    fun resolve(value: Value?): Value? = when (val d = deref(value)) {
        is Value.Struct -> Value.Struct(d.functor, d.args.map { resolve(it) })
        is Value.ListVal -> Value.ListVal(d.items.map { resolve(it) ?: it })
        else -> d
    }

    fun bind(register: String, value: Value?) {
        trail.add(register)
        registers[register] = value
    }

    fun bindTarget(register: String, value: Value?) {
        val current = deref(registers[register])
        if (current is Value.Var) {
            bind(current.name, value)
        }
        bind(register, value)
    }

    fun unify(left: Value?, right: Value?): Boolean {
        val lhs = deref(left)
        val rhs = deref(right)
        if (lhs == rhs) return true
        if (lhs is Value.Var) {
            bind(lhs.name, rhs)
            return true
        }
        if (rhs is Value.Var) {
            bind(rhs.name, lhs)
            return true
        }
        if (lhs is Value.Struct && rhs is Value.Struct && lhs.functor == rhs.functor && lhs.args.size == rhs.args.size) {
            return lhs.args.zip(rhs.args).all { (l, r) -> unify(l, r) }
        }
        if (lhs is Value.ListVal && rhs is Value.ListVal && lhs.items.size == rhs.items.size) {
            return lhs.items.zip(rhs.items).all { (l, r) -> unify(l, r) }
        }
        return false
    }

    fun snapshotRegisters(): Map<String, Value?> = registers.toSortedMap().mapValues { resolve(it.value) }

    fun beginStructure(functor: String, register: String): Boolean {
        val arity = functorArity(functor) ?: return false
        val current = deref(registers[register])
        if (current == null || current is Value.Var) {
            context = WamContext.Write(register, functor, arity)
            return true
        }
        if (current is Value.Struct && current.functor == functor && current.args.size == arity) {
            context = WamContext.Read(current.args)
            return true
        }
        return false
    }

    fun pushWriteArg(value: Value?): Boolean {
        val ctx = context as? WamContext.Write ?: return false
        ctx.args.add(value)
        if (ctx.args.size == ctx.arity) {
            bindTarget(ctx.targetRegister, Value.Struct(ctx.functor, ctx.args.toList()))
            context = null
        }
        return true
    }

    fun nextReadArg(): Value? {
        val ctx = context as? WamContext.Read ?: return null
        if (ctx.index !in ctx.args.indices) return null
        val value = ctx.args[ctx.index]
        ctx.index += 1
        if (ctx.index >= ctx.args.size) context = null
        return value
    }
}

class WamProgram {
    private val predicates: MutableMap<String, List<Instruction>> = linkedMapOf()

    fun register(name: String, instructions: List<Instruction>) {
        predicates[name] = instructions
    }

    fun instructionsFor(name: String): List<Instruction> =
        predicates[name] ?: error("Unknown WAM predicate: $name")

    fun predicateNames(): Set<String> = predicates.keys
}

class WamRuntime(private val program: WamProgram) {
    fun run(predicate: String, initialState: WamState = WamState()): WamState {
        val instructions = program.instructionsFor(predicate)
        initialState.pc = 0
        while (initialState.pc in instructions.indices) {
            if (!step(initialState, instructions[initialState.pc])) {
                error("WAM instruction failed at pc=${initialState.pc}: ${instructions[initialState.pc]}")
            }
        }
        return initialState
    }

    fun step(state: WamState, instruction: Instruction): Boolean {
        when (instruction.op) {
            "put_constant", "put_integer", "put_float", "put_nil" -> {
                val value = instruction.args.getOrNull(0) as? Value ?: return false
                val register = instruction.args.getOrNull(1) as? String ?: return false
                state.registers[register] = value
                state.pc += 1
                return true
            }
            "put_variable" -> {
                val variable = instruction.args.getOrNull(0) as? String ?: return false
                val register = instruction.args.getOrNull(1) as? String ?: return false
                val value = Value.Var(variable)
                state.registers[variable] = value
                state.registers[register] = value
                state.pc += 1
                return true
            }
            "put_value", "put_unsafe_value" -> {
                val source = instruction.args.getOrNull(0) as? String ?: return false
                val target = instruction.args.getOrNull(1) as? String ?: return false
                state.registers[target] = state.deref(state.registers[source]) ?: return false
                state.pc += 1
                return true
            }
            "put_structure" -> {
                val functor = instruction.args.getOrNull(0) as? String ?: return false
                val register = instruction.args.getOrNull(1) as? String ?: return false
                if (!state.beginStructure(functor, register)) return false
                state.pc += 1
                return true
            }
            "put_list" -> {
                val register = instruction.args.getOrNull(0) as? String ?: return false
                if (!state.beginStructure("[|]/2", register)) return false
                state.pc += 1
                return true
            }
            "get_constant", "get_integer", "get_float", "get_nil" -> {
                val expected = instruction.args.getOrNull(0) as? Value ?: return false
                val register = instruction.args.getOrNull(1) as? String ?: return false
                val current = state.deref(state.registers[register])
                if (current == null) {
                    state.bind(register, expected)
                    state.pc += 1
                    return true
                }
                if (current is Value.Var) {
                    state.bind(current.name, expected)
                    state.pc += 1
                    return true
                }
                if (current == expected) {
                    state.pc += 1
                    return true
                }
                return false
            }
            "get_variable" -> {
                val variable = instruction.args.getOrNull(0) as? String ?: return false
                val argument = instruction.args.getOrNull(1) as? String ?: return false
                val value = state.deref(state.registers[argument]) ?: Value.Var(variable)
                state.registers[variable] = value
                state.registers[argument] = value
                state.pc += 1
                return true
            }
            "get_value" -> {
                val variable = instruction.args.getOrNull(0) as? String ?: return false
                val argument = instruction.args.getOrNull(1) as? String ?: return false
                val left = state.registers[variable] ?: Value.Var(variable).also { state.registers[variable] = it }
                val right = state.registers[argument] ?: Value.Var(argument).also { state.registers[argument] = it }
                if (!state.unify(left, right)) return false
                state.pc += 1
                return true
            }
            "get_structure" -> {
                val functor = instruction.args.getOrNull(0) as? String ?: return false
                val register = instruction.args.getOrNull(1) as? String ?: return false
                if (!state.beginStructure(functor, register)) return false
                state.pc += 1
                return true
            }
            "get_list" -> {
                val register = instruction.args.getOrNull(0) as? String ?: return false
                if (!state.beginStructure("[|]/2", register)) return false
                state.pc += 1
                return true
            }
            "set_variable" -> {
                val variable = instruction.args.getOrNull(0) as? String ?: return false
                val value = Value.Var(variable)
                state.registers[variable] = value
                if (!state.pushWriteArg(value)) return false
                state.pc += 1
                return true
            }
            "set_value", "set_local_value" -> {
                val register = instruction.args.getOrNull(0) as? String ?: return false
                if (!state.pushWriteArg(state.deref(state.registers[register]) ?: return false)) return false
                state.pc += 1
                return true
            }
            "set_constant", "set_integer" -> {
                val value = instruction.args.getOrNull(0) as? Value ?: return false
                if (!state.pushWriteArg(value)) return false
                state.pc += 1
                return true
            }
            "set_nil" -> {
                if (!state.pushWriteArg(Value.Atom("[]"))) return false
                state.pc += 1
                return true
            }
            "unify_variable" -> {
                val variable = instruction.args.getOrNull(0) as? String ?: return false
                val ctx = state.context
                if (ctx is WamContext.Write) {
                    val value = Value.Var(variable)
                    state.registers[variable] = value
                    if (!state.pushWriteArg(value)) return false
                } else {
                    val value = state.nextReadArg() ?: return false
                    state.registers[variable] = state.deref(value)
                }
                state.pc += 1
                return true
            }
            "unify_value" -> {
                val register = instruction.args.getOrNull(0) as? String ?: return false
                val ctx = state.context
                if (ctx is WamContext.Write) {
                    if (!state.pushWriteArg(state.deref(state.registers[register]) ?: Value.Var(register))) return false
                } else {
                    val value = state.nextReadArg() ?: return false
                    val regValue = state.registers[register] ?: Value.Var(register).also { state.registers[register] = it }
                    if (!state.unify(regValue, value)) return false
                }
                state.pc += 1
                return true
            }
            "unify_constant" -> {
                val value = instruction.args.getOrNull(0) as? Value ?: return false
                val ctx = state.context
                if (ctx is WamContext.Write) {
                    if (!state.pushWriteArg(value)) return false
                } else {
                    if (!state.unify(state.nextReadArg(), value)) return false
                }
                state.pc += 1
                return true
            }
            "unify_nil" -> {
                val value = Value.Atom("[]")
                val ctx = state.context
                if (ctx is WamContext.Write) {
                    if (!state.pushWriteArg(value)) return false
                } else {
                    if (!state.unify(state.nextReadArg(), value)) return false
                }
                state.pc += 1
                return true
            }
            "builtin_call" -> {
                val op = instruction.args.getOrNull(0) as? String ?: return false
                val arity = (instruction.args.getOrNull(1) as? Long)?.toInt() ?: return false
                if (op == "=/2" && arity == 2) {
                    if (!state.unify(state.registers["A1"], state.registers["A2"])) return false
                    state.pc += 1
                    return true
                }
                return false
            }
            "call", "execute", "allocate", "deallocate" -> {
                state.pc += 1
                return true
            }
            "proceed" -> {
                state.pc = Int.MAX_VALUE
                return true
            }
            "fail" -> {
                return false
            }
            else -> {
                // Unsupported instructions fail closed.  The generated registrar still
                // preserves their op/args so future runtime work is ABI-compatible.
                return false
            }
        }
    }
}

fun functorArity(functor: String): Int? =
    functor.substringAfterLast('/', missingDelimiterValue = "").toIntOrNull()

fun parseWamCliValue(token: String): Value =
    parseStructToken(token)
        ?: token.toLongOrNull()?.let { Value.IntVal(it) }
        ?: token.toDoubleOrNull()?.let { Value.FloatVal(it) }
        ?: Value.Atom(token)

fun parseStructToken(token: String): Value.Struct? {
    val open = token.indexOf('(')
    if (open <= 0 || !token.endsWith(")")) return null
    val functor = token.substring(0, open)
    val body = token.substring(open + 1, token.length - 1)
    val args = if (body.isBlank()) emptyList() else body.split(',').map { parseWamCliValue(it.trim()) }
    return Value.Struct("$functor/${args.size}", args)
}

fun stateFromCliArgs(values: List<String>): WamState {
    val state = WamState()
    values.forEachIndexed { index, raw ->
        state.registers["A${index + 1}"] = parseWamCliValue(raw)
    }
    return state
}
