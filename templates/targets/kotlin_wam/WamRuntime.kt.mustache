package {{package}}

// Generated by UnifyWeaver Kotlin Hybrid WAM target.
// This runtime intentionally starts small but executable: it provides the
// stable ABI used by generated predicate registrars and a deterministic core
// instruction subset for facts, constants, variables, equality, simple calls,
// and first-order compound/list term construction and matching.  Rich
// choicepoint/indexing semantics are added incrementally without changing
// registrar output.

sealed class Value {
    data class Atom(val name: String) : Value()
    data class IntVal(val value: Long) : Value()
    data class FloatVal(val value: Double) : Value()
    data class Var(val name: String) : Value()
    data class Ref(val address: Int) : Value()
    data class Struct(val functor: String, val args: List<Value?>) : Value()
    data class ListVal(val items: List<Value>) : Value()
}

data class Instruction(val op: String, val args: List<Any?> = emptyList())

data class PredicateCode(
    val instructions: List<Instruction>,
    val labels: Map<String, Int>,
)

data class CallFrame(
    val code: PredicateCode,
    val returnPc: Int,
    val context: WamContext?,
    val environmentStack: List<EnvironmentFrame>,
)

data class EnvironmentFrame(
    val id: Int,
    val slots: MutableMap<String, Value?> = linkedMapOf(),
)

sealed class WamContext {
    data class Read(val args: List<Value?>, var index: Int = 0) : WamContext()
    data class Write(
        val targetRegister: String,
        val functor: String,
        val arity: Int,
        val args: MutableList<Value?> = mutableListOf(),
    ) : WamContext()
}

data class ChoicePoint(
    val code: PredicateCode,
    val pc: Int,
    val registers: MutableMap<String, Value?>,
    val trailSize: Int,
    val context: WamContext?,
    val callStack: List<CallFrame>,
    val environmentStack: List<EnvironmentFrame>,
)

class WamState(
    var pc: Int = 0,
    val registers: MutableMap<String, Value?> = linkedMapOf(),
    val heap: MutableList<Value?> = mutableListOf(),
    val trail: MutableList<String> = mutableListOf(),
    val choicePoints: MutableList<ChoicePoint> = mutableListOf(),
    val callStack: MutableList<CallFrame> = mutableListOf(),
    val environmentStack: MutableList<EnvironmentFrame> = mutableListOf(),
    var context: WamContext? = null,
    private var nextEnvironmentId: Int = 0,
    private var nextHeapVarId: Int = 0,
) {
    fun isEnvironmentRegister(register: String): Boolean =
        register.startsWith("Y")

    fun currentEnvironment(): EnvironmentFrame? = environmentStack.lastOrNull()

    fun environmentBankContaining(register: String): MutableMap<String, Value?>? =
        environmentStack.asReversed().firstOrNull { register in it.slots }?.slots

    fun registerBank(register: String): MutableMap<String, Value?> =
        if (isEnvironmentRegister(register)) currentEnvironment()?.slots ?: registers else registers

    fun bindingBank(register: String): MutableMap<String, Value?> =
        if (isEnvironmentRegister(register)) environmentBankContaining(register) ?: registerBank(register) else registers

    fun scopedRegisterName(register: String): String =
        if (isEnvironmentRegister(register)) currentEnvironment()?.let { "${register}@E${it.id}" } ?: register else register

    fun readRegister(register: String): Value? =
        if (isEnvironmentRegister(register)) environmentBankContaining(register)?.get(register) ?: registers[register] else registers[register]

    fun writeRegister(register: String, value: Value?) {
        registerBank(register)[register] = value
    }

    fun newVariable(register: String): Value.Var {
        // Heap identity independent of the register name (Xn or Yn).
        // Structure/list cells and arithmetic trees store this Var; later
        // unify_variable/writeRegister on the register must not clobber
        // already-built terms, and bindings must survive recursive
        // call/execute across allocate frames (KT-LIST-BACKTRACK +
        // KT-Y-ENV-RECURSION). Scoped Y@E names lived in environment
        // slots that recursive allocate/call could miss on deref.
        val heapName = "H${nextHeapVarId++}"
        val value = Value.Var(heapName)
        registers[heapName] = value
        writeRegister(register, value)
        return value
    }

    fun snapshotEnvironmentStack(): List<EnvironmentFrame> =
        environmentStack.map { EnvironmentFrame(it.id, LinkedHashMap(it.slots)) }

    fun restoreEnvironmentStack(snapshot: List<EnvironmentFrame>) {
        environmentStack.clear()
        environmentStack.addAll(snapshot.map { EnvironmentFrame(it.id, LinkedHashMap(it.slots)) })
    }

    fun allocateEnvironment() {
        environmentStack.add(EnvironmentFrame(nextEnvironmentId++))
    }

    fun deallocateEnvironment() {
        if (environmentStack.isNotEmpty()) {
            environmentStack.removeAt(environmentStack.lastIndex)
        }
    }

    fun deref(value: Value?): Value? = when (value) {
        is Value.Var -> {
            val bound = readRegister(value.name)
            if (bound == null || bound == value) value else deref(bound)
        }
        else -> value
    }

    fun resolve(value: Value?): Value? = when (val d = deref(value)) {
        is Value.Struct -> Value.Struct(d.functor, d.args.map { resolve(it) })
        is Value.ListVal -> Value.ListVal(d.items.map { resolve(it) ?: it })
        else -> d
    }

    fun bind(register: String, value: Value?) {
        trail.add(register)
        bindingBank(register)[register] = value
    }

    fun bindTarget(register: String, value: Value?) {
        // A-REGISTER EXCEPTION (M139/M140 bind-through class): A
        // registers are argument staging — their old occupant is an
        // unrelated variable (often a clause-head argument), and
        // binding it to the freshly built term creates a cyclic term
        // (X = f(X)), wrong-failing a later X = 1. Top-down
        // structure-chaining placeholders only ever live in X/Y
        // registers, so the bind-through is conditioned on the register
        // class — the same fix the Rust, Go, Scala and LLVM targets carry.
        if (!register.startsWith("A")) {
            val current = deref(readRegister(register))
            if (current is Value.Var) {
                bind(current.name, value)
            }
        }
        bind(register, value)
    }

    fun unify(left: Value?, right: Value?): Boolean {
        val lhs = deref(left)
        val rhs = deref(right)
        if (lhs == rhs) return true
        if (lhs is Value.Var) {
            bind(lhs.name, rhs)
            return true
        }
        if (rhs is Value.Var) {
            bind(rhs.name, lhs)
            return true
        }
        if (lhs is Value.Struct && rhs is Value.Struct && lhs.functor == rhs.functor && lhs.args.size == rhs.args.size) {
            return lhs.args.zip(rhs.args).all { (l, r) -> unify(l, r) }
        }
        if (lhs is Value.ListVal && rhs is Value.ListVal && lhs.items.size == rhs.items.size) {
            return lhs.items.zip(rhs.items).all { (l, r) -> unify(l, r) }
        }
        return false
    }

    fun snapshotRegisters(): Map<String, Value?> {
        val snapshot = linkedMapOf<String, Value?>()
        snapshot.putAll(registers)
        environmentStack.forEach { snapshot.putAll(it.slots) }
        return snapshot.toSortedMap().mapValues { resolve(it.value) }
    }

    fun beginStructure(functor: String, register: String): Boolean {
        val arity = functorArity(functor) ?: return false
        val current = deref(readRegister(register))
        if (current == null || current is Value.Var) {
            context = WamContext.Write(register, functor, arity)
            return true
        }
        if (current is Value.Struct && current.functor == functor && current.args.size == arity) {
            context = WamContext.Read(current.args)
            return true
        }
        return false
    }

    fun beginStructurePut(functor: String, register: String): Boolean {
        // put-family structure start: WRITE mode unconditionally. The
        // target register is being OVERWRITTEN, so its stale occupant
        // must not be consulted — routing put_structure/put_list through
        // beginStructure (get-style dispatch) wrong-failed them whenever
        // the register still held a constant, e.g. a clause-head
        // argument about to be replaced by the goal argument.
        val arity = functorArity(functor) ?: return false
        context = WamContext.Write(register, functor, arity)
        return true
    }

    fun pushWriteArg(value: Value?): Boolean {
        val ctx = context as? WamContext.Write ?: return false
        ctx.args.add(value)
        if (ctx.args.size == ctx.arity) {
            bindTarget(ctx.targetRegister, Value.Struct(ctx.functor, ctx.args.toList()))
            context = null
        }
        return true
    }

    fun nextReadArg(): Value? {
        val ctx = context as? WamContext.Read ?: return null
        if (ctx.index !in ctx.args.indices) return null
        val value = ctx.args[ctx.index]
        ctx.index += 1
        if (ctx.index >= ctx.args.size) context = null
        return value
    }

    fun saveChoicePoint(code: PredicateCode, pc: Int) {
        choicePoints.add(ChoicePoint(code, pc, LinkedHashMap(registers), trail.size, context, callStack.toList(), snapshotEnvironmentStack()))
    }

    fun restoreChoicePointFrame(): ChoicePoint? {
        val cp = choicePoints.removeLastOrNull() ?: return null
        registers.clear()
        registers.putAll(cp.registers)
        while (trail.size > cp.trailSize) {
            trail.removeAt(trail.lastIndex)
        }
        callStack.clear()
        callStack.addAll(cp.callStack)
        restoreEnvironmentStack(cp.environmentStack)
        context = cp.context
        pc = cp.pc
        return cp
    }

    fun restoreChoicePoint(): Boolean = restoreChoicePointFrame() != null

    // Optional profile counters (KT-HEAP-SNAPSHOT-OPT-2): attribute ALL
    // snapshotForNative cost — including T4 `_t4` — not only tryRun.
    var profileSnaps: Boolean = false
    var profileSnapNs: Long = 0L
    var profileSnapCount: Long = 0L
    var profileMaxRegisterMapSize: Int = 0
    var profileSumRegisterMapSize: Long = 0L

    fun resetSnapProfile() {
        profileSnapNs = 0L
        profileSnapCount = 0L
        profileMaxRegisterMapSize = 0
        profileSumRegisterMapSize = 0L
    }

    fun snapshotForNative(): WamNativeSnapshot {
        if (profileSnaps) {
            val mapSize = registers.size
            if (mapSize > profileMaxRegisterMapSize) profileMaxRegisterMapSize = mapSize
            profileSumRegisterMapSize += mapSize.toLong()
            val t0 = System.nanoTime()
            val snap = snapshotForNativeUnprofiled()
            profileSnapNs += System.nanoTime() - t0
            profileSnapCount++
            return snap
        }
        return snapshotForNativeUnprofiled()
    }

    private fun snapshotForNativeUnprofiled(): WamNativeSnapshot =
        WamNativeSnapshot(
            registers = LinkedHashMap(registers),
            trail = trail.toList(),
            choicePoints = choicePoints.map { cp ->
                ChoicePoint(
                    cp.code,
                    cp.pc,
                    LinkedHashMap(cp.registers),
                    cp.trailSize,
                    cp.context,
                    cp.callStack.toList(),
                    cp.environmentStack.map { EnvironmentFrame(it.id, LinkedHashMap(it.slots)) },
                )
            },
            callStack = callStack.map { frame ->
                CallFrame(
                    frame.code,
                    frame.returnPc,
                    frame.context,
                    frame.environmentStack.map { EnvironmentFrame(it.id, LinkedHashMap(it.slots)) },
                )
            },
            environmentStack = snapshotEnvironmentStack(),
            context = context,
            pc = pc,
        )

    fun restoreFromSnapshot(snapshot: WamNativeSnapshot) {
        registers.clear()
        registers.putAll(snapshot.registers)
        trail.clear()
        trail.addAll(snapshot.trail)
        choicePoints.clear()
        choicePoints.addAll(snapshot.choicePoints)
        callStack.clear()
        callStack.addAll(snapshot.callStack)
        restoreEnvironmentStack(snapshot.environmentStack)
        context = snapshot.context
        pc = snapshot.pc
    }
}

data class WamNativeSnapshot(
    val registers: Map<String, Value?>,
    val trail: List<String>,
    val choicePoints: List<ChoicePoint>,
    val callStack: List<CallFrame>,
    val environmentStack: List<EnvironmentFrame>,
    val context: WamContext?,
    val pc: Int,
)

// Native lowered predicates. The dispatch callback is WamRuntime.tryRun —
// used for last-call `execute P/N` (EMIT-KOTLIN-4). Non-execute bodies ignore it.
typealias WamNativeFn = (WamState, (String, WamState) -> Boolean) -> Boolean

class WamProgram {
    private val predicates: MutableMap<String, PredicateCode> = linkedMapOf()
    private val natives: MutableMap<String, WamNativeFn> = linkedMapOf()

    fun register(name: String, instructions: List<Instruction>) {
        val labels = linkedMapOf<String, Int>()
        instructions.forEachIndexed { index, instruction ->
            if (instruction.op == "label") {
                (instruction.args.getOrNull(0) as? String)?.let { labels[it] = index }
            }
        }
        predicates[name] = PredicateCode(instructions, labels)
    }

    fun registerNative(key: String, fn: WamNativeFn) {
        natives[key] = fn
    }

    fun findNative(key: String): WamNativeFn? = natives[key]

    fun findCode(name: String): PredicateCode? = predicates[name]

    fun codeFor(name: String): PredicateCode =
        findCode(name) ?: error("Unknown WAM predicate: $name")

    fun instructionsFor(name: String): List<Instruction> = codeFor(name).instructions

    fun predicateNames(): Set<String> = predicates.keys
}

class WamRuntime(private val program: WamProgram) {
    private lateinit var currentCode: PredicateCode

    // Depth of nested native tryRun entries. Top-level (=0→1) keeps the
    // WAT-style snapshot+bytecode fallback (T5 unbound A1, incomplete
    // lowering). Recursive hops (execute→dispatch→tryRun) skip it when
    // skipRecursiveNativeSnapshot is true (KT-DISPATCH-SNAPSHOT-OPT):
    // T4 already snapshots per clause (`_t4`).
    private var nativeDepth: Int = 0

    /** When true (default), recursive native hops skip snapshotForNative. */
    var skipRecursiveNativeSnapshot: Boolean = true

    // Optional nanoTime counters for dispatch profiling (append_500 etc.).
    // Snap time/count live on the WamState used for each tryRun (includes T4 `_t4`).
    // Aggregate into these fields across a timed batch via noteStateProfile().
    var profileNativeDispatch: Boolean = false
    var profileSnapNs: Long = 0L
    var profileSnapCount: Long = 0L
    var profileNativeEntries: Long = 0L
    var profileMaxRegisterMapSize: Int = 0
    var profileSumRegisterMapSize: Long = 0L

    fun resetProfileCounters() {
        profileSnapNs = 0L
        profileSnapCount = 0L
        profileNativeEntries = 0L
        profileMaxRegisterMapSize = 0
        profileSumRegisterMapSize = 0L
    }

    /** Fold per-query state snap counters into the runtime aggregate (bench PROFILE). */
    fun noteStateProfile(state: WamState) {
        if (!profileNativeDispatch) return
        profileSnapNs += state.profileSnapNs
        profileSnapCount += state.profileSnapCount
        if (state.profileMaxRegisterMapSize > profileMaxRegisterMapSize) {
            profileMaxRegisterMapSize = state.profileMaxRegisterMapSize
        }
        profileSumRegisterMapSize += state.profileSumRegisterMapSize
    }

    fun run(predicate: String, initialState: WamState = WamState()): WamState {
        if (!tryRun(predicate, initialState)) {
            error("WAM predicate failed: $predicate")
        }
        return initialState
    }

    // Conformance / boolean entry: native-first, then bytecode; false on
    // exhaustion (no throw). Used by conformance_main projects so ct_run
    // can map stdout true/false without relying on exceptions.
    fun tryRun(predicate: String, initialState: WamState = WamState()): Boolean {
        if (profileNativeDispatch) {
            initialState.profileSnaps = true
        }
        program.findNative(predicate)?.let { nativeFn ->
            profileNativeEntries++
            val recursive = nativeDepth > 0
            // Recursive native hop: no full-state snapshot, no bytecode
            // fallback. Clause-level backtracking is owned by the lowered
            // T4 `_t4` snapshot; a native `false` here is a genuine fail.
            if (recursive && skipRecursiveNativeSnapshot) {
                return nativeFn(initialState, this::tryRun)
            }
            // Top-level (or recursive with skip disabled for A/B profile):
            // snapshot so a native false can restore before falling back
            // to bytecode (T5 unbound → interpreter, etc.).
            val snapshot = initialState.snapshotForNative()
            nativeDepth++
            val ok = try {
                nativeFn(initialState, this::tryRun)
            } finally {
                nativeDepth--
            }
            if (ok) return true
            if (program.findCode(predicate) == null) {
                initialState.restoreFromSnapshot(snapshot)
                return false
            }
            initialState.restoreFromSnapshot(snapshot)
        }
        val code = program.findCode(predicate) ?: return false
        currentCode = code
        initialState.pc = 0
        while (initialState.pc in currentCode.instructions.indices) {
            val instruction = currentCode.instructions[initialState.pc]
            if (!step(initialState, instruction) && !restoreChoicePoint(initialState)) {
                return false
            }
        }
        return true
    }

    fun restoreChoicePoint(state: WamState): Boolean {
        val cp = state.restoreChoicePointFrame() ?: return false
        currentCode = cp.code
        return true
    }

    fun enterPredicate(state: WamState, predicate: String, returnPc: Int? = null): Boolean {
        val nextCode = program.findCode(predicate) ?: return false
        if (returnPc != null) {
            state.callStack.add(CallFrame(currentCode, returnPc, state.context, state.snapshotEnvironmentStack()))
        }
        currentCode = nextCode
        state.context = null
        state.pc = 0
        return true
    }

    fun returnFromPredicate(state: WamState): Boolean {
        val frame = state.callStack.removeLastOrNull() ?: return false
        currentCode = frame.code
        state.restoreEnvironmentStack(frame.environmentStack)
        state.context = frame.context
        state.pc = frame.returnPc
        return true
    }

    fun jumpToLabel(state: WamState, label: String): Boolean {
        val target = currentCode.labels[label] ?: return false
        state.pc = target
        return true
    }

    fun parseSwitchEntries(rawEntries: Any?): Map<String, String> {
        val entries = rawEntries as? List<*> ?: return emptyMap()
        return entries.mapNotNull { raw ->
            val entry = raw as? String ?: return@mapNotNull null
            val parts = entry.split(":", limit = 2)
            if (parts.size == 2) parts[0] to parts[1] else null
        }.toMap()
    }

    fun valueSwitchKey(value: Value?): String? = when (val resolved = value) {
        is Value.Atom -> resolved.name
        is Value.IntVal -> resolved.value.toString()
        is Value.FloatVal -> resolved.value.toString()
        is Value.Struct -> resolved.functor
        else -> null
    }

    fun switchOn(state: WamState, register: String, rawEntries: Any?, structureMode: Boolean = false): Boolean {
        val entries = parseSwitchEntries(rawEntries)
        val value = state.deref(state.readRegister(register))
        val key = if (structureMode) (value as? Value.Struct)?.functor else valueSwitchKey(value)
        val target = key?.let { entries[it] } ?: entries["default"]
        if (target == null || target == "default") {
            state.pc += 1
            return true
        }
        return jumpToLabel(state, target)
    }

    // M148: arithmetic evaluation for is/2 and the arith compares.
    // Handles numeric leaves and the standard binary/unary operators
    // built via put_structure. Returns null for non-evaluable input
    // (ISO lax semantics: the builtin then fails).
    fun evalArith(state: WamState, value: Value?): Value? {
        return when (val d = state.resolve(value)) {
            is Value.IntVal -> d
            is Value.FloatVal -> d
            is Value.Struct -> {
                // Functor keys are "name/arity". Strip only the trailing
                // "/<digits>" — a naive split("/") breaks slash-bearing ops
                // like "//" (key "///2") and "/" (key "//2").
                val name = functorName(d.functor)
                if (d.args.size == 2) {
                    val a = evalArith(state, d.args[0]) ?: return null
                    val b = evalArith(state, d.args[1]) ?: return null
                    if (a is Value.IntVal && b is Value.IntVal) {
                        val x = a.value; val y = b.value
                        when (name) {
                            "+" -> Value.IntVal(x + y)
                            "-" -> Value.IntVal(x - y)
                            "*" -> Value.IntVal(x * y)
                            "//" -> if (y == 0L) null else Value.IntVal(x / y)
                            "mod" -> if (y == 0L) null else Value.IntVal(Math.floorMod(x, y))
                            "/" -> if (y == 0L) null else if (x % y == 0L) Value.IntVal(x / y) else Value.FloatVal(x.toDouble() / y)
                            else -> null
                        }
                    } else {
                        val x = arithDouble(a); val y = arithDouble(b)
                        when (name) {
                            "+" -> Value.FloatVal(x + y)
                            "-" -> Value.FloatVal(x - y)
                            "*" -> Value.FloatVal(x * y)
                            "/" -> if (y == 0.0) null else Value.FloatVal(x / y)
                            else -> null
                        }
                    }
                } else if (d.args.size == 1 && name == "-") {
                    when (val a = evalArith(state, d.args[0])) {
                        is Value.IntVal -> Value.IntVal(-a.value)
                        is Value.FloatVal -> Value.FloatVal(-a.value)
                        else -> null
                    }
                } else null
            }
            else -> null
        }
    }

    fun arithDouble(v: Value): Double = when (v) {
        is Value.IntVal -> v.value.toDouble()
        is Value.FloatVal -> v.value
        else -> Double.NaN
    }

    fun step(state: WamState, instruction: Instruction): Boolean {
        when (instruction.op) {
            "label" -> {
                state.pc += 1
                return true
            }
            "try_me_else" -> {
                val label = instruction.args.getOrNull(0) as? String ?: return false
                val target = currentCode.labels[label] ?: return false
                state.saveChoicePoint(currentCode, target)
                state.pc += 1
                return true
            }
            "retry_me_else" -> {
                val label = instruction.args.getOrNull(0) as? String ?: return false
                val target = currentCode.labels[label] ?: return false
                state.saveChoicePoint(currentCode, target)
                state.pc += 1
                return true
            }
            "trust_me" -> {
                state.pc += 1
                return true
            }
            "try", "retry", "trust", "jump" -> {
                val label = instruction.args.getOrNull(0) as? String ?: return false
                return jumpToLabel(state, label)
            }
            "switch_on_constant", "switch_on_constant_fallthrough" -> {
                return switchOn(state, "A1", instruction.args.getOrNull(0))
            }
            "switch_on_constant_a2", "switch_on_constant_a2_fallthrough" -> {
                return switchOn(state, "A2", instruction.args.getOrNull(0))
            }
            "switch_on_structure" -> {
                return switchOn(state, "A1", instruction.args.getOrNull(0), structureMode = true)
            }
            "switch_on_structure_a2" -> {
                return switchOn(state, "A2", instruction.args.getOrNull(0), structureMode = true)
            }
            "switch_on_term", "switch_on_term_a2" -> {
                state.pc += 1
                return true
            }
            "put_constant", "put_integer", "put_float", "put_nil" -> {
                val value = instruction.args.getOrNull(0) as? Value ?: return false
                val register = instruction.args.getOrNull(1) as? String ?: return false
                state.writeRegister(register, value)
                state.pc += 1
                return true
            }
            "put_variable" -> {
                val variable = instruction.args.getOrNull(0) as? String ?: return false
                val register = instruction.args.getOrNull(1) as? String ?: return false
                val value = state.newVariable(variable)
                state.writeRegister(register, value)
                state.pc += 1
                return true
            }
            "put_value", "put_unsafe_value" -> {
                val source = instruction.args.getOrNull(0) as? String ?: return false
                val target = instruction.args.getOrNull(1) as? String ?: return false
                state.writeRegister(target, state.deref(state.readRegister(source)) ?: return false)
                state.pc += 1
                return true
            }
            "put_structure" -> {
                val functor = instruction.args.getOrNull(0) as? String ?: return false
                val register = instruction.args.getOrNull(1) as? String ?: return false
                if (!state.beginStructurePut(functor, register)) return false
                state.pc += 1
                return true
            }
            "put_list" -> {
                val register = instruction.args.getOrNull(0) as? String ?: return false
                if (!state.beginStructurePut("[|]/2", register)) return false
                state.pc += 1
                return true
            }
            "get_constant", "get_integer", "get_float", "get_nil" -> {
                val expected = instruction.args.getOrNull(0) as? Value ?: return false
                val register = instruction.args.getOrNull(1) as? String ?: return false
                val current = state.deref(state.readRegister(register))
                if (current == null) {
                    state.bind(register, expected)
                    state.pc += 1
                    return true
                }
                if (current is Value.Var) {
                    state.bind(current.name, expected)
                    state.pc += 1
                    return true
                }
                if (current == expected) {
                    state.pc += 1
                    return true
                }
                return false
            }
            "get_variable" -> {
                val variable = instruction.args.getOrNull(0) as? String ?: return false
                val argument = instruction.args.getOrNull(1) as? String ?: return false
                val value = state.deref(state.readRegister(argument)) ?: state.newVariable(variable)
                state.writeRegister(variable, value)
                state.writeRegister(argument, value)
                state.pc += 1
                return true
            }
            "get_value" -> {
                val variable = instruction.args.getOrNull(0) as? String ?: return false
                val argument = instruction.args.getOrNull(1) as? String ?: return false
                val left = state.readRegister(variable) ?: state.newVariable(variable)
                val right = state.readRegister(argument) ?: state.newVariable(argument)
                if (!state.unify(left, right)) return false
                state.pc += 1
                return true
            }
            "get_structure" -> {
                val functor = instruction.args.getOrNull(0) as? String ?: return false
                val register = instruction.args.getOrNull(1) as? String ?: return false
                if (!state.beginStructure(functor, register)) return false
                state.pc += 1
                return true
            }
            "get_list" -> {
                val register = instruction.args.getOrNull(0) as? String ?: return false
                if (!state.beginStructure("[|]/2", register)) return false
                state.pc += 1
                return true
            }
            "set_variable" -> {
                val variable = instruction.args.getOrNull(0) as? String ?: return false
                val value = state.newVariable(variable)
                if (!state.pushWriteArg(value)) return false
                state.pc += 1
                return true
            }
            "set_value", "set_local_value" -> {
                val register = instruction.args.getOrNull(0) as? String ?: return false
                if (!state.pushWriteArg(state.deref(state.readRegister(register)) ?: return false)) return false
                state.pc += 1
                return true
            }
            "set_constant", "set_integer" -> {
                val value = instruction.args.getOrNull(0) as? Value ?: return false
                if (!state.pushWriteArg(value)) return false
                state.pc += 1
                return true
            }
            "set_nil" -> {
                if (!state.pushWriteArg(Value.Atom("[]"))) return false
                state.pc += 1
                return true
            }
            "unify_variable" -> {
                val variable = instruction.args.getOrNull(0) as? String ?: return false
                val ctx = state.context
                if (ctx is WamContext.Write) {
                    val value = state.newVariable(variable)
                    if (!state.pushWriteArg(value)) return false
                } else {
                    val value = state.nextReadArg() ?: return false
                    state.writeRegister(variable, state.deref(value))
                }
                state.pc += 1
                return true
            }
            "unify_value" -> {
                val register = instruction.args.getOrNull(0) as? String ?: return false
                val ctx = state.context
                if (ctx is WamContext.Write) {
                    if (!state.pushWriteArg(state.deref(state.readRegister(register)) ?: state.newVariable(register))) return false
                } else {
                    val value = state.nextReadArg() ?: return false
                    val regValue = state.readRegister(register) ?: state.newVariable(register)
                    if (!state.unify(regValue, value)) return false
                }
                state.pc += 1
                return true
            }
            "unify_constant" -> {
                val value = instruction.args.getOrNull(0) as? Value ?: return false
                val ctx = state.context
                if (ctx is WamContext.Write) {
                    if (!state.pushWriteArg(value)) return false
                } else {
                    if (!state.unify(state.nextReadArg(), value)) return false
                }
                state.pc += 1
                return true
            }
            "unify_nil" -> {
                val value = Value.Atom("[]")
                val ctx = state.context
                if (ctx is WamContext.Write) {
                    if (!state.pushWriteArg(value)) return false
                } else {
                    if (!state.unify(state.nextReadArg(), value)) return false
                }
                state.pc += 1
                return true
            }
            "builtin_call" -> {
                val op = instruction.args.getOrNull(0) as? String ?: return false
                val arity = (instruction.args.getOrNull(1) as? Long)?.toInt() ?: return false
                if (op == "=/2" && arity == 2) {
                    if (!state.unify(state.readRegister("A1"), state.readRegister("A2"))) return false
                    state.pc += 1
                    return true
                }
                // M148: the table previously implemented ONLY =/2 - every
                // other builtin (var/1, is/2, =:=/2, even true/0) failed
                // closed, so no type check or arithmetic ever ran.
                when (op) {
                    "true/0" -> { state.pc += 1; return true }
                    "==/2" -> {
                        if (state.resolve(state.readRegister("A1")) != state.resolve(state.readRegister("A2"))) return false
                        state.pc += 1; return true
                    }
                    "\\==/2" -> {
                        if (state.resolve(state.readRegister("A1")) == state.resolve(state.readRegister("A2"))) return false
                        state.pc += 1; return true
                    }
                    "var/1" -> {
                        if (state.deref(state.readRegister("A1")) !is Value.Var) return false
                        state.pc += 1; return true
                    }
                    "nonvar/1" -> {
                        if (state.deref(state.readRegister("A1")) is Value.Var) return false
                        state.pc += 1; return true
                    }
                    "atom/1" -> {
                        if (state.deref(state.readRegister("A1")) !is Value.Atom) return false
                        state.pc += 1; return true
                    }
                    "integer/1" -> {
                        if (state.deref(state.readRegister("A1")) !is Value.IntVal) return false
                        state.pc += 1; return true
                    }
                    "number/1" -> {
                        val d = state.deref(state.readRegister("A1"))
                        if (d !is Value.IntVal && d !is Value.FloatVal) return false
                        state.pc += 1; return true
                    }
                    "atomic/1" -> {
                        when (state.deref(state.readRegister("A1"))) {
                            is Value.Atom, is Value.IntVal, is Value.FloatVal -> { state.pc += 1; return true }
                            else -> return false
                        }
                    }
                    "is/2" -> {
                        val result = evalArith(state, state.readRegister("A2")) ?: return false
                        if (!state.unify(state.readRegister("A1"), result)) return false
                        state.pc += 1; return true
                    }
                    "=:=/2", "=\\=/2", "</2", ">/2", "=</2", ">=/2" -> {
                        val a = arithDouble(evalArith(state, state.readRegister("A1")) ?: return false)
                        val b = arithDouble(evalArith(state, state.readRegister("A2")) ?: return false)
                        val ok = when (op) {
                            "=:=/2" -> a == b
                            "=\\=/2" -> a != b
                            "</2" -> a < b
                            ">/2" -> a > b
                            "=</2" -> a <= b
                            else -> a >= b
                        }
                        if (!ok) return false
                        state.pc += 1; return true
                    }
                }
                return false
            }
            "call" -> {
                val predicate = instruction.args.getOrNull(0) as? String ?: return false
                return enterPredicate(state, predicate, returnPc = state.pc + 1)
            }
            "execute" -> {
                val predicate = instruction.args.getOrNull(0) as? String ?: return false
                return enterPredicate(state, predicate)
            }
            "allocate" -> {
                state.allocateEnvironment()
                state.pc += 1
                return true
            }
            "deallocate" -> {
                state.deallocateEnvironment()
                state.pc += 1
                return true
            }
            "proceed" -> {
                if (!returnFromPredicate(state)) {
                    state.pc = Int.MAX_VALUE
                }
                return true
            }
            "fail" -> {
                return false
            }
            "cut_ite" -> {
                // M148: if-then-else commit. Previously unimplemented (fail
                // closed), so a successful condition backtracked through the
                // try_me_else choicepoint into the else branch - the M144
                // bug class, fifth target found with it.
                state.choicePoints.removeLastOrNull()
                state.pc += 1
                return true
            }
            "jump" -> {
                val label = instruction.args.getOrNull(0) as? String ?: return false
                val target = currentCode.labels[label] ?: return false
                state.pc = target
                return true
            }
            "get_level" -> {
                val reg = instruction.args.getOrNull(0) as? String ?: return false
                state.writeRegister(reg, Value.IntVal(state.choicePoints.size.toLong()))
                state.pc += 1
                return true
            }
            "cut" -> {
                val reg = instruction.args.getOrNull(0) as? String ?: return false
                val depth = (state.deref(state.readRegister(reg)) as? Value.IntVal)?.value?.toInt()
                if (depth != null) {
                    while (state.choicePoints.size > depth) state.choicePoints.removeAt(state.choicePoints.lastIndex)
                }
                state.pc += 1
                return true
            }
            else -> {
                // Unsupported instructions fail closed.  The generated registrar still
                // preserves their op/args so future runtime work is ABI-compatible.
                return false
            }
        }
    }
}

fun functorArity(functor: String): Int? =
    functor.substringAfterLast('/', missingDelimiterValue = "").toIntOrNull()

// Companion to functorArity: name is everything before the LAST '/', so
// "///2" → "//", "//2" → "/", "+/2" → "+".
fun functorName(functor: String): String =
    functor.substringBeforeLast('/', missingDelimiterValue = functor)

fun parseWamCliValue(token: String): Value =
    parseStructToken(token)
        ?: token.toLongOrNull()?.let { Value.IntVal(it) }
        ?: token.toDoubleOrNull()?.let { Value.FloatVal(it) }
        ?: Value.Atom(token)

fun parseStructToken(token: String): Value.Struct? {
    val open = token.indexOf('(')
    if (open <= 0 || !token.endsWith(")")) return null
    val functor = token.substring(0, open)
    val body = token.substring(open + 1, token.length - 1)
    val args = if (body.isBlank()) emptyList() else body.split(',').map { parseWamCliValue(it.trim()) }
    return Value.Struct("$functor/${args.size}", args)
}

fun stateFromCliArgs(values: List<String>): WamState {
    val state = WamState()
    values.forEachIndexed { index, raw ->
        state.writeRegister("A${index + 1}", parseWamCliValue(raw))
    }
    return state
}

/** Build `[1,2,...,n]` as nested `[|]/2` cons cells (benchmark / CLI helper). */
fun intRangeList(n: Int): Value {
    var acc: Value = Value.Atom("[]")
    for (i in n downTo 1) {
        acc = Value.Struct("[|]/2", listOf(Value.IntVal(i.toLong()), acc))
    }
    return acc
}

// Lowered-predicate helpers (single-clause WAM fast path).
fun kotlinLoGetConstant(state: WamState, expected: Value, register: String): Boolean {
    val current = state.deref(state.readRegister(register))
    return when {
        current == null -> {
            state.bind(register, expected)
            true
        }
        current is Value.Var -> {
            state.bind(current.name, expected)
            true
        }
        current == expected -> true
        else -> false
    }
}

fun kotlinLoGetValue(state: WamState, variable: String, argument: String): Boolean {
    val left = state.readRegister(variable) ?: state.newVariable(variable)
    val right = state.readRegister(argument) ?: state.newVariable(argument)
    return state.unify(left, right)
}

fun kotlinLoUnifyVariable(state: WamState, variable: String): Boolean {
  return when (val ctx = state.context) {
        is WamContext.Write -> state.pushWriteArg(state.newVariable(variable))
        else -> {
            val value = state.nextReadArg() ?: return false
            state.writeRegister(variable, state.deref(value))
            true
        }
    }
}

fun kotlinLoUnifyValue(state: WamState, register: String): Boolean {
    return when (val ctx = state.context) {
        is WamContext.Write ->
            state.pushWriteArg(state.deref(state.readRegister(register)) ?: state.newVariable(register))
        else -> {
            val value = state.nextReadArg() ?: return false
            val regValue = state.readRegister(register) ?: state.newVariable(register)
            state.unify(regValue, value)
        }
    }
}

fun kotlinLoUnifyConstant(state: WamState, value: Value): Boolean {
    return when (state.context) {
        is WamContext.Write -> state.pushWriteArg(value)
        else -> state.unify(state.nextReadArg(), value)
    }
}
