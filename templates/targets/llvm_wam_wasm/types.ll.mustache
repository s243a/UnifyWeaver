; Generated by UnifyWeaver WAM-to-LLVM WASM Target
; Date: {{date}}
; Module: {{module_name}}
; Target: wasm32

; === Value Tagged Union ===
; Tag: 0=Atom, 1=Integer, 2=Float, 3=Compound, 4=List, 5=Ref, 6=Unbound, 7=Bool
; Note: payload is i64 even on wasm32 — WASM supports i64 natively
%Value = type { i32, i64 }

; === Compound and List (linear memory offsets) ===
; On wasm32, pointers are i32 offsets into linear memory
%Compound = type { i32, i32, i32 }        ; functor offset, arity, args offset
%List = type { i32, i32 }                 ; length, elements offset

; === Instruction Tagged Union ===
%Instruction = type { i32, i64, i64 }     ; tag, operand1, operand2

; === Stack Entries ===
; Type: 0=EnvFrame, 1=UnifyCtx, 2=WriteCtx
%StackEntry = type { i32, i64, i32 }      ; type, aux (cp or n), data offset

; === Trail Entry ===
%TrailEntry = type { i32, %Value }        ; register index, old value

; === Choice Point ===
%ChoicePoint = type {
    i32,                                   ; next_pc
    [32 x %Value],                         ; saved registers
    i32,                                   ; trail mark
    i32                                    ; saved cp
}

; === WAM State ===
; On wasm32, all pointer fields are i32 offsets into linear memory.
; We use a flat struct allocated from the bump allocator.
%WamState = type {
    i32,                                   ; 0: pc
    [32 x %Value],                         ; 1: regs
    i32,                                   ; 2: stack offset (in linear memory)
    i32,                                   ; 3: stack_size
    i32,                                   ; 4: stack_cap
    i32,                                   ; 5: heap offset (in linear memory)
    i32,                                   ; 6: heap_size
    i32,                                   ; 7: heap_cap
    i32,                                   ; 8: trail offset
    i32,                                   ; 9: trail_size
    i32,                                   ; 10: trail_cap
    i32,                                   ; 11: cp (continuation pointer)
    i32,                                   ; 12: choice_points offset
    i32,                                   ; 13: cp_count
    i32,                                   ; 14: cp_cap
    %Instruction*,                         ; 15: code (pointer, not offset — static data)
    i32,                                   ; 16: code_length
    i32*,                                  ; 17: labels (pointer — static data)
    i32,                                   ; 18: label_count
    i1                                     ; 19: halted
}
