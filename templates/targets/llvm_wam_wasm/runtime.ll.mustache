; === WAM Runtime for WASM ===
; Key difference from native: no musttail (WASM doesn't support it).
; run_loop uses a while loop instead.

; Step: execute a single WAM instruction via switch dispatch
{{step_function}}

; Run loop: iterative (no musttail — WASM has no guaranteed TCO).
; This loop is semantically equivalent to the native musttail version:
;   1. Check halted → success
;   2. Fetch instruction at PC → failure if out of bounds
;   3. Step (dispatch via switch) → on success, loop back to 1
;   4. On step failure → backtrack (restore choice point, rewind trail)
;   5. If backtrack succeeds → loop back to 1; else → failure
; Choice point saves/restores are handled entirely within step() (try_me_else)
; and backtrack(), so the loop body itself is stateless between iterations.
define i1 @run_loop(%WamState* %vm) {
entry:
  br label %loop

loop:
  %halted = call i1 @wam_is_halted(%WamState* %vm)
  br i1 %halted, label %success, label %fetch_instr

fetch_instr:
  %instr = call %Instruction* @wam_fetch(%WamState* %vm)
  %null_check = icmp eq %Instruction* %instr, null
  br i1 %null_check, label %failure, label %do_step

do_step:
  %ok = call i1 @step(%WamState* %vm, %Instruction* %instr)
  br i1 %ok, label %loop, label %try_backtrack

try_backtrack:
  %bt_ok = call i1 @backtrack(%WamState* %vm)
  br i1 %bt_ok, label %loop, label %failure

success:
  ret i1 true

failure:
  ret i1 false
}

