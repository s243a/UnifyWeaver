; === WASM Bump Allocator ===
; Linear memory bump allocator — no malloc/free needed.
; Heap starts at offset 65536 (64KB reserved for stack).
; On backtracking, the heap pointer is rewound.

@wam_heap_ptr = global i32 65536    ; Start after WASM stack

; Allocate from linear memory (bump allocator)
define i32 @wam_alloc(i32 %size) {
entry:
  %ptr = load i32, i32* @wam_heap_ptr
  ; Align to 8 bytes
  %aligned_size = add i32 %size, 7
  %masked = and i32 %aligned_size, -8
  %new_ptr = add i32 %ptr, %masked
  store i32 %new_ptr, i32* @wam_heap_ptr
  ret i32 %ptr
}

; Rewind allocator to a saved mark (for backtracking)
define void @wam_alloc_rewind(i32 %mark) {
entry:
  store i32 %mark, i32* @wam_heap_ptr
  ret void
}

; Get current allocation mark (for saving before choice point)
define i32 @wam_alloc_mark() {
entry:
  %mark = load i32, i32* @wam_heap_ptr
  ret i32 %mark
}

; Zero-fill a region (for initialization)
define void @wam_memzero(i32 %offset, i32 %len) {
entry:
  %done = icmp sle i32 %len, 0
  br i1 %done, label %exit, label %loop

loop:
  %idx = phi i32 [0, %entry], [%next, %loop]
  %addr = add i32 %offset, %idx
  %ptr = inttoptr i32 %addr to i8*
  store i8 0, i8* %ptr
  %next = add i32 %idx, 1
  %more = icmp slt i32 %next, %len
  br i1 %more, label %loop, label %exit

exit:
  ret void
}

; Copy memory (for register save/restore in choice points)
define void @wam_memcpy(i32 %dest, i32 %src, i32 %len) {
entry:
  %done = icmp sle i32 %len, 0
  br i1 %done, label %exit, label %loop

loop:
  %idx = phi i32 [0, %entry], [%next, %loop]
  %src_addr = add i32 %src, %idx
  %dest_addr = add i32 %dest, %idx
  %src_ptr = inttoptr i32 %src_addr to i8*
  %dest_ptr = inttoptr i32 %dest_addr to i8*
  %byte = load i8, i8* %src_ptr
  store i8 %byte, i8* %dest_ptr
  %next = add i32 %idx, 1
  %more = icmp slt i32 %next, %len
  br i1 %more, label %loop, label %exit

exit:
  ret void
}
