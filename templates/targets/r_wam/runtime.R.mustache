WamRuntime <- new.env(parent = emptyenv())

# ----------------------------------------------------------
# Atom intern table
# ----------------------------------------------------------
# Mutable, append-only. Seeded by generated_program.R from the codegen-
# discovered atoms; new atoms are added on demand.
#
# Implemented as an environment so mutations propagate (R lists copy on
# update). The string -> id map uses match() over $arr, which is O(N)
# but the table stays small in the scaffold; a hashed env can replace
# this when it becomes a hotspot. We deliberately avoid exists()/get()
# because they reject syntactically-invalid names like "" and "[]".
WamRuntime$new_intern_table <- function(initial) {
  e <- new.env(parent = emptyenv())
  e$arr <- character(0)
  for (s in as.character(initial)) {
    if (is.na(match(s, e$arr))) {
      e$arr <- c(e$arr, s)
    }
  }
  e
}

WamRuntime$intern <- function(table, s) {
  s <- as.character(s)
  idx <- match(s, table$arr)
  if (!is.na(idx)) return(idx - 1L)
  table$arr <- c(table$arr, s)
  length(table$arr) - 1L
}

WamRuntime$string_of <- function(table, id) {
  if (id >= 0L && id < length(table$arr)) table$arr[id + 1L]
  else paste0("<atom:", id, ">")
}

# ----------------------------------------------------------
# Value constructors (tagged lists)
# ----------------------------------------------------------
Atom        <- function(id)        list(tag = "atom",     id = as.integer(id))
IntTerm     <- function(n)         list(tag = "int",      val = as.integer(n))
FloatTerm   <- function(n)         list(tag = "float",    val = as.numeric(n))
Unbound     <- function(name)      list(tag = "unbound",  name = name)
StructTerm  <- function(fid, args) list(tag = "struct",   fid = as.integer(fid), args = args)

wam_is_atom     <- function(v) is.list(v) && !is.null(v$tag) && v$tag == "atom"
wam_is_integer  <- function(v) is.list(v) && !is.null(v$tag) && v$tag == "int"
wam_is_float    <- function(v) is.list(v) && !is.null(v$tag) && v$tag == "float"
wam_is_number   <- function(v) wam_is_integer(v) || wam_is_float(v)
wam_is_var      <- function(v) is.list(v) && !is.null(v$tag) && v$tag == "unbound"
wam_is_compound <- function(v) is.list(v) && !is.null(v$tag) && v$tag == "struct"

wam_term_to_string <- function(v, table = NULL) {
  if (is.null(v)) return("<null>")
  switch(v$tag,
    "atom"    = if (!is.null(table)) WamRuntime$string_of(table, v$id) else paste0("<atom:", v$id, ">"),
    "int"     = as.character(v$val),
    "float"   = as.character(v$val),
    "unbound" = paste0("_", v$name),
    "struct"  = {
      head <- if (!is.null(table)) WamRuntime$string_of(table, v$fid) else paste0("<atom:", v$fid, ">")
      paste0(head, "(", paste(vapply(v$args, wam_term_to_string, character(1), table = table), collapse = ","), ")")
    },
    "<unknown>"
  )
}

wam_member <- function(elem, lst) {
  for (x in lst) {
    if (identical(x, elem)) return(TRUE)
  }
  FALSE
}

