# ----------------------------------------------------------
# WamState -- mutable environment-record
# ----------------------------------------------------------
WamRuntime$new_state <- function() {
  s <- new.env(parent = emptyenv())
  s$pc          <- 1L                       # 1-based; matches R indexing
  s$cp          <- 0L                       # 0 = top-level
  s$regs        <- list()                   # integer-keyed: regs[[as.character(idx)]]
  s$stack       <- list()                   # env frames
  s$cps         <- list()                   # choice-point stack
  s$bindings    <- new.env(parent = emptyenv(), hash = TRUE)
  s$trail       <- list()
  s$var_counter <- 0L
  s$halt        <- FALSE                    # set by foreign top-level wrapper
  s
}

WamRuntime$get_reg <- function(state, idx) {
  key <- as.character(idx)
  if (exists(key, envir = state$regs2, inherits = FALSE)) {
    get(key, envir = state$regs2, inherits = FALSE)
  } else {
    NULL
  }
}

WamRuntime$put_reg <- function(state, idx, val) {
  key <- as.character(idx)
  assign(key, val, envir = state$regs2)
  invisible(NULL)
}

# Promote $regs from a plain list to an environment for O(1) update.
# Called once at run_predicate entry; lazy migration keeps the data
# model self-describing for inspection in the REPL.
WamRuntime$promote_regs <- function(state) {
  e <- new.env(parent = emptyenv(), hash = TRUE)
  for (k in names(state$regs)) {
    assign(k, state$regs[[k]], envir = e)
  }
  state$regs2 <- e
}

# ----------------------------------------------------------
# Dereferencing & unification
# ----------------------------------------------------------
WamRuntime$deref <- function(state, v) {
  while (is.list(v) && !is.null(v$tag) && v$tag == "unbound") {
    name <- v$name
    if (!exists(name, envir = state$bindings, inherits = FALSE)) break
    v <- get(name, envir = state$bindings, inherits = FALSE)
  }
  v
}

WamRuntime$bind <- function(state, name, val) {
  assign(name, val, envir = state$bindings)
  state$trail <- c(state$trail, list(name))
  invisible(NULL)
}

WamRuntime$unify <- function(state, a, b) {
  a <- WamRuntime$deref(state, a)
  b <- WamRuntime$deref(state, b)
  if (is.null(a) || is.null(b)) return(FALSE)
  if (identical(a, b)) return(TRUE)
  if (a$tag == "unbound") { WamRuntime$bind(state, a$name, b); return(TRUE) }
  if (b$tag == "unbound") { WamRuntime$bind(state, b$name, a); return(TRUE) }
  if (a$tag != b$tag) return(FALSE)
  switch(a$tag,
    "atom"   = identical(a$id, b$id),
    "int"    = identical(a$val, b$val),
    "float"  = identical(a$val, b$val),
    "struct" = {
      if (!identical(a$fid, b$fid)) return(FALSE)
      if (length(a$args) != length(b$args)) return(FALSE)
      for (i in seq_along(a$args)) {
        if (!WamRuntime$unify(state, a$args[[i]], b$args[[i]])) return(FALSE)
      }
      TRUE
    },
    FALSE
  )
}

# ----------------------------------------------------------
# Step dispatch
# ----------------------------------------------------------
# Returns TRUE on success, FALSE on instruction failure (caller should
# trigger backtracking). Most instructions advance state$pc by 1; control
# instructions set $pc themselves.
WamRuntime$step <- function(program, state, instr) {
  switch(instr$op,
    "GetConstant" = {
      val <- WamRuntime$deref(state, WamRuntime$get_reg(state, instr$ai))
      if (is.null(val)) { return(FALSE) }
      if (val$tag == "unbound") {
        WamRuntime$bind(state, val$name, instr$c)
        WamRuntime$put_reg(state, instr$ai, instr$c)
      } else if (!identical(val, instr$c)) {
        return(FALSE)
      }
      state$pc <- state$pc + 1L; TRUE
    },
    "GetVariable" = {
      v <- WamRuntime$get_reg(state, instr$ai)
      WamRuntime$put_reg(state, instr$xn, v)
      state$pc <- state$pc + 1L; TRUE
    },
    "GetValue" = {
      a <- WamRuntime$get_reg(state, instr$ai)
      x <- WamRuntime$get_reg(state, instr$xn)
      ok <- WamRuntime$unify(state, a, x)
      if (!ok) return(FALSE)
      state$pc <- state$pc + 1L; TRUE
    },
    "PutConstant" = {
      WamRuntime$put_reg(state, instr$ai, instr$c)
      state$pc <- state$pc + 1L; TRUE
    },
    "PutVariable" = {
      v <- Unbound(paste0("V", state$var_counter))
      state$var_counter <- state$var_counter + 1L
      WamRuntime$put_reg(state, instr$xn, v)
      WamRuntime$put_reg(state, instr$ai, v)
      state$pc <- state$pc + 1L; TRUE
    },
    "PutValue" = {
      v <- WamRuntime$get_reg(state, instr$xn)
      WamRuntime$put_reg(state, instr$ai, v)
      state$pc <- state$pc + 1L; TRUE
    },
    "Allocate" = {
      state$stack <- c(state$stack, list(list(cp = state$cp, locals = new.env(parent = emptyenv()))))
      state$pc <- state$pc + 1L; TRUE
    },
    "Deallocate" = {
      n <- length(state$stack)
      if (n > 0L) {
        state$cp    <- state$stack[[n]]$cp
        state$stack <- state$stack[-n]
      }
      state$pc <- state$pc + 1L; TRUE
    },
    "Call" = {
      key <- paste0(instr$pred, "/", instr$arity)
      tgt <- program$labels[[key]]
      if (is.null(tgt)) return(FALSE)
      state$cp <- state$pc + 1L
      state$pc <- as.integer(tgt)
      TRUE
    },
    "Execute" = {
      key <- paste0(instr$pred, "/", instr$arity)
      tgt <- program$labels[[key]]
      if (is.null(tgt)) return(FALSE)
      state$pc <- as.integer(tgt)
      TRUE
    },
    "CallForeign" = {
      ok <- WamRuntime$call_foreign(program, state, instr$pred, instr$arity, tail_call = FALSE)
      if (!ok) return(FALSE)
      state$pc <- state$pc + 1L; TRUE
    },
    "ExecuteForeign" = {
      ok <- WamRuntime$call_foreign(program, state, instr$pred, instr$arity, tail_call = TRUE)
      if (!ok) return(FALSE)
      # tail-call returns to caller's CP
      if (state$cp == 0L) { state$halt <- TRUE; return(TRUE) }
      state$pc <- state$cp; state$cp <- 0L; TRUE
    },
    "Proceed" = {
      if (state$cp == 0L) { state$halt <- TRUE; return(TRUE) }
      state$pc <- state$cp; state$cp <- 0L; TRUE
    },
    "TryMeElse" = {
      cp <- list(
        next_pc      = program$labels[[instr$label]],
        regs         = as.list.environment(state$regs2),
        cp           = state$cp,
        trail_len    = length(state$trail),
        var_counter  = state$var_counter
      )
      state$cps <- c(state$cps, list(cp))
      state$pc <- state$pc + 1L; TRUE
    },
    "RetryMeElse" = {
      n <- length(state$cps)
      if (n == 0L) return(FALSE)
      state$cps[[n]]$next_pc <- program$labels[[instr$label]]
      state$pc <- state$pc + 1L; TRUE
    },
    "TrustMe" = {
      n <- length(state$cps)
      if (n > 0L) state$cps <- state$cps[-n]
      state$pc <- state$pc + 1L; TRUE
    },
    "Jump" = {
      tgt <- program$labels[[instr$label]]
      if (is.null(tgt)) return(FALSE)
      state$pc <- as.integer(tgt); TRUE
    },
    "CutIte" = {
      n <- length(state$cps)
      if (n > 0L) state$cps <- state$cps[-n]
      state$pc <- state$pc + 1L; TRUE
    },
    "SwitchOnConstant" = {
      # WAM-emitter convention: each case carries a label to jump to,
      # or the literal string "default" meaning "no shortcut, advance to
      # the next instruction (the standard try/retry chain)". Cases
      # whose label is unresolved in program$labels also fall through.
      v <- WamRuntime$deref(state, WamRuntime$get_reg(state, 1L))
      target <- NULL
      if (!is.null(v) && v$tag == "atom") {
        for (case in instr$cases) {
          if (identical(case$value$id, v$id)) { target <- case$label; break }
        }
      }
      tgt <- if (!is.null(target) && target != "default") program$labels[[target]] else NULL
      if (is.null(tgt)) {
        state$pc <- state$pc + 1L
      } else {
        state$pc <- as.integer(tgt)
      }
      TRUE
    },
    "BuiltinCall" = {
      ok <- WamRuntime$call_builtin(program, state, instr$pred, instr$arity)
      if (!ok) return(FALSE)
      state$pc <- state$pc + 1L; TRUE
    },
    "Raw" = {
      stop(paste0("unrecognized WAM instruction: ", instr$text))
    },
    stop(paste0("not implemented: ", instr$op))
  )
}

WamRuntime$call_foreign <- function(program, state, pred, arity, tail_call) {
  key <- paste0(pred, "/", arity)
  handler <- program$foreign_handlers[[key]]
  if (is.null(handler)) {
    return(FALSE)
  }
  # args are A1..A<arity>
  args <- vector("list", arity)
  for (i in seq_len(arity)) {
    args[[i]] <- WamRuntime$get_reg(state, i)
  }
  res <- handler(state, args, program$intern_table)
  if (is.null(res) || isTRUE(res$ok == FALSE)) return(FALSE)
  # On success the handler may have written register bindings via the
  # mutable state; we accept that and let the caller advance the PC.
  TRUE
}

WamRuntime$call_builtin <- function(program, state, pred, arity) {
  # Stub: minimal builtins. Extend as the lowered emitter matures.
  if (pred == "true" && arity == 0L) return(TRUE)
  if (pred == "fail" && arity == 0L) return(FALSE)
  # Unknown builtin -> failure (matches WAM convention).
  FALSE
}

# ----------------------------------------------------------
# Backtracking
# ----------------------------------------------------------
WamRuntime$backtrack <- function(state) {
  n <- length(state$cps)
  if (n == 0L) return(FALSE)
  cp <- state$cps[[n]]
  # Restore registers
  e <- new.env(parent = emptyenv(), hash = TRUE)
  for (k in names(cp$regs)) assign(k, cp$regs[[k]], envir = e)
  state$regs2 <- e
  # Unbind trail entries beyond cp$trail_len
  if (length(state$trail) > cp$trail_len) {
    to_undo <- state$trail[(cp$trail_len + 1L):length(state$trail)]
    for (name in to_undo) {
      if (exists(name, envir = state$bindings, inherits = FALSE)) {
        rm(list = name, envir = state$bindings)
      }
    }
    state$trail <- state$trail[seq_len(cp$trail_len)]
  }
  state$cp <- cp$cp
  state$var_counter <- cp$var_counter
  state$pc <- as.integer(cp$next_pc)
  TRUE
}

# ----------------------------------------------------------
# Top-level driver
# ----------------------------------------------------------
WamRuntime$run <- function(program, state, max_steps = 1e7) {
  for (i in seq_len(max_steps)) {
    if (state$halt) return(TRUE)
    if (state$pc < 1L || state$pc > length(program$instructions)) {
      if (!WamRuntime$backtrack(state)) return(FALSE)
      next
    }
    instr <- program$instructions[[state$pc]]
    ok <- WamRuntime$step(program, state, instr)
    if (!ok) {
      if (!WamRuntime$backtrack(state)) return(FALSE)
    }
  }
  warning("WAM run exceeded max_steps; truncating")
  FALSE
}

WamRuntime$run_predicate <- function(program, start_pc, args) {
  state <- WamRuntime$new_state()
  state$regs <- list()
  WamRuntime$promote_regs(state)
  for (i in seq_along(args)) {
    WamRuntime$put_reg(state, i, args[[i]])
  }
  state$pc <- as.integer(start_pc)
  state$cp <- 0L
  WamRuntime$run(program, state)
}
