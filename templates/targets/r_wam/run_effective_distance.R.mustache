weight_sum_for_category_root <- function(category, root) {
  res <- run_weight_query(category, root)
  if (!isTRUE(res$ok)) return(NULL)
  res$value
}

compute_rows <- function(article_pairs, roots) {
  cats_by_article <- new.env(parent = emptyenv())
  for (pair in article_pairs) {
    art <- pair[[1L]]
    cat <- pair[[2L]]
    prev <- cats_by_article[[art]]
    if (is.null(prev)) cats_by_article[[art]] <- cat
    else cats_by_article[[art]] <- c(prev, cat)
  }
  articles <- sort(ls(cats_by_article, all.names = TRUE))
  inv_n <- -1.0 / DIMENSION_N
  rows <- list()
  for (root in roots) {
    seed_weights <- new.env(parent = emptyenv())
    for (article in articles) {
      cats <- unique(as.character(cats_by_article[[article]]))
      weight_sum <- 0.0
      for (cat in cats) {
        if (identical(cat, root)) {
          weight_sum <- weight_sum + 1.0
          next
        }
        cached <- seed_weights[[cat]]
        if (is.null(cached)) {
          w <- weight_sum_for_category_root(cat, root)
          cached <- if (is.null(w) || !(w > 0)) 0.0 else w
          seed_weights[[cat]] <- cached
        }
        if (cached > 0) weight_sum <- weight_sum + cached
      }
      if (weight_sum > 0) {
        rows[[length(rows) + 1L]] <- list(
          article = article,
          root = root,
          distance = weight_sum ^ inv_n
        )
      }
    }
  }
  if (length(rows) == 0L) return(rows)
  order_idx <- order(
    vapply(rows, function(r) r$distance, numeric(1)),
    vapply(rows, function(r) r$article, character(1)),
    vapply(rows, function(r) r$root, character(1))
  )
  rows[order_idx]
}

main <- function(args) {
  total_t0 <- proc.time()[["elapsed"]]
  if (length(args) < 1L) {
    cat("Usage: Rscript run_effective_distance.R <benchmark-data-dir> [reps]\n",
        file = stderr())
    quit(status = 1L)
  }
  data_dir <- args[[1L]]
  reps <- if (length(args) >= 2L) as.integer(args[[2L]]) else 1L
  if (is.na(reps) || reps < 1L) reps <- 1L

  article_path <- file.path(data_dir, "article_category.tsv")
  root_path <- file.path(data_dir, "root_categories.tsv")
  article_pairs <- load_tsv_pairs(article_path)
  roots <- load_single_column(root_path)
  if (length(roots) == 0L) {
    cat("no root categories\n", file = stderr())
    quit(status = 1L)
  }

  query_ms_samples <- integer(0)
  rows <- list()
  for (rep in seq_len(reps)) {
    t_q <- proc.time()[["elapsed"]]
    rows <- compute_rows(article_pairs, roots)
    q_ms <- as.integer(round((proc.time()[["elapsed"]] - t_q) * 1000))
    query_ms_samples <- c(query_ms_samples, q_ms)
  }
  query_ms <- as.integer(median(query_ms_samples))
  total_ms <- as.integer(round((proc.time()[["elapsed"]] - total_t0) * 1000))

  cat(sprintf("mode=r_wam_effective_distance\n"), file = stderr())
  cat(sprintf("kernel_mode=%s\n", KERNEL_MODE), file = stderr())
  cat(sprintf("emit_mode=%s\n", EMIT_MODE), file = stderr())
  cat(sprintf("query_ms=%d\n", query_ms), file = stderr())
  cat(sprintf("total_ms=%d\n", total_ms), file = stderr())
  cat(sprintf("row_count=%d\n", length(rows)), file = stderr())
  if (length(query_ms_samples) > 1L) {
    cat(sprintf("query_ms_samples=%s\n",
                paste(query_ms_samples, collapse = ",")), file = stderr())
  }

  cat("article\troot_category\teffective_distance\n")
  for (row in rows) {
    cat(sprintf("%s\t%s\t%.6f\n", row$article, row$root, row$distance))
  }
}

if (!interactive() && sys.nframe() == 0L) {
