load_tsv_pairs <- function(path) {
  if (!file.exists(path)) stop("missing TSV: ", path)
  lines <- readLines(path, warn = FALSE)
  out <- list()
  for (line in lines) {
    trimmed <- trimws(line)
    if (!nzchar(trimmed) || startsWith(trimmed, "#")) next
    if (identical(trimmed, "article\tcategory") ||
        identical(trimmed, "child\tparent") ||
        identical(trimmed, "article\troot_category\teffective_distance")) next
    parts <- strsplit(trimmed, "\t", fixed = TRUE)[[1L]]
    if (length(parts) < 2L) next
    out[[length(out) + 1L]] <- c(parts[[1L]], parts[[2L]])
  }
  out
}

load_single_column <- function(path) {
  if (!file.exists(path)) stop("missing TSV: ", path)
  lines <- readLines(path, warn = FALSE)
  out <- character(0)
  for (line in lines) {
    trimmed <- trimws(line)
    if (!nzchar(trimmed) || startsWith(trimmed, "#")) next
    if (identical(trimmed, "root") || identical(trimmed, "category")) next
    out <- c(out, trimmed)
  }
  out
}

bench_atom <- function(name) {
  Atom(WamRuntime$intern(intern_table, as.character(name)))
}

