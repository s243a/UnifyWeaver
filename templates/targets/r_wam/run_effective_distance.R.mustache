  WamRuntime$put_reg(state, 2L, bench_atom(root))
  WamRuntime$put_reg(state, 3L, weight)
  state$cp <- 0L
{{match emit_mode}}{{case functions}}
  fn <- if (exists(WEIGHT_KEY, envir = shared_program$lowered_dispatch, inherits = FALSE)) {
          get(WEIGHT_KEY, envir = shared_program$lowered_dispatch, inherits = FALSE)
        } else if (exists("lowered_category_ancestor_effective_distance_sum_selected_3",
                          inherits = TRUE)) {
          lowered_category_ancestor_effective_distance_sum_selected_3
        } else {
          NULL
        }
  ok <- if (!is.null(fn)) {
    isTRUE(fn(shared_program, state))
  } else {
    pc <- shared_program$labels[[WEIGHT_KEY]] %||% shared_program$dispatch[[WEIGHT_KEY]]
    if (is.null(pc)) return(list(ok = FALSE, value = NULL))
    state$pc <- as.integer(pc)
    isTRUE(tryCatch(WamRuntime$run(shared_program, state),
                    prolog_throw = function(cond) FALSE))
  }
{{case interpreter}}
  pc <- shared_program$labels[[WEIGHT_KEY]] %||% shared_program$dispatch[[WEIGHT_KEY]]
