#!/usr/bin/awk -f
# Generated by UnifyWeaver AWK Target - Transitive Closure
# Predicate: {{pred}}/2 (transitive closure of {{base}})
# Input: from:to pairs on stdin
# Usage: echo "a:b\nb:c" | awk -f {{pred}}.awk -v start=a [-v target=c]

BEGIN {
    edge_count = 0
}

# Read base relation edges
/:/ {
    split($0, parts, ":")
    from = parts[1]
    to = parts[2]
    # Remove leading/trailing whitespace
    gsub(/^[ \t]+|[ \t]+$/, "", from)
    gsub(/^[ \t]+|[ \t]+$/, "", to)
    edge_count++
    edges[edge_count, "from"] = from
    edges[edge_count, "to"] = to
    # Build adjacency list
    if (!(from in adj_count)) adj_count[from] = 0
    adj_count[from]++
    adj[from, adj_count[from]] = to
}

END {
    if (start == "") {
        print "Usage: awk -f {{pred}}.awk -v start=NODE [-v target=NODE]" > "/dev/stderr"
        exit 1
    }

    # BFS reachability
    queue[1] = start
    queue_head = 1
    queue_tail = 1
    visited[start] = 1

    while (queue_head <= queue_tail) {
        current = queue[queue_head]
        queue_head++

        if (target != "" && current == target && current != start) {
            print start ":" target
            exit 0
        }

        if (current in adj_count) {
            for (i = 1; i <= adj_count[current]; i++) {
                next_node = adj[current, i]
                if (!(next_node in visited)) {
                    visited[next_node] = 1
                    queue_tail++
                    queue[queue_tail] = next_node
                    if (target == "") {
                        print start ":" next_node
                    }
                }
            }
        }
    }

    if (target != "") {
        exit 1
    }
}
