#!/usr/bin/env Rscript
# Generated by UnifyWeaver R Target - Transitive Closure
# Predicate: {{pred}}/2 (transitive closure of {{base}})

# Adjacency list stored as an environment (hash map)
{{base}}_graph <- new.env(hash = TRUE, parent = emptyenv())

add_{{base}} <- function(from_node, to_node) {
    if (!exists(from_node, envir = {{base}}_graph)) {
        assign(from_node, character(0), envir = {{base}}_graph)
    }
    assign(from_node, c(get(from_node, envir = {{base}}_graph), to_node), envir = {{base}}_graph)
}

# Find all reachable nodes from start (BFS)
{{pred}}_all <- function(start) {
    visited <- start
    queue <- start
    results <- character(0)

    while (length(queue) > 0) {
        current <- queue[1]
        queue <- queue[-1]
        neighbors <- tryCatch(get(current, envir = {{base}}_graph), error = function(e) character(0))
        for (next_node in neighbors) {
            if (!(next_node %in% visited)) {
                visited <- c(visited, next_node)
                queue <- c(queue, next_node)
                results <- c(results, next_node)
            }
        }
    }
    results
}

# Check if target is reachable from start
{{pred}}_check <- function(start, target) {
    if (start == target) return(FALSE)
    visited <- start
    queue <- start

    while (length(queue) > 0) {
        current <- queue[1]
        queue <- queue[-1]
        neighbors <- tryCatch(get(current, envir = {{base}}_graph), error = function(e) character(0))
        for (next_node in neighbors) {
            if (next_node == target) return(TRUE)
            if (!(next_node %in% visited)) {
                visited <- c(visited, next_node)
                queue <- c(queue, next_node)
            }
        }
    }
    FALSE
}
