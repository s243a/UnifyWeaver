            name (normalize-literal-atom ctx (functor-name-from-key key))]
        (list->term ctx (cons name (:args term*))))

      (or (atom-term? term*) (number? term*))
      (list->term ctx [term*])

      :else
      nil)))

(defn univ-compose-term [state list-value]
  (when-let [items (proper-list-items state list-value)]
    (when (seq items)
      (if (= 1 (count items))
        [state (deref-value (:bindings state) (first items))]
        (let [head (deref-value (:bindings state) (first items))
              args (vec (rest items))]
          (when (atom-term? head)
            (let [name (deintern-atom (:intern-context state) (:id head))
                  functor-key (str name "/" (count args))
                  [ctx* functor-id] (intern-atom (:intern-context state) functor-key)
                  state* (assoc state :intern-context ctx*)]
              [state* (structure-term (atom-term functor-id) args)])))))))

(defn apply-univ-solution [state]
  (let [raw-term (or (reg-get-raw state "A1") ::unbound)
        term (deref-value (:bindings state) raw-term)
        out (deref-value (:bindings state)
                         (or (reg-get-raw state "A2") ::unbound))]
    (if (logic-var? term)
      (if-let [[compose-state built] (univ-compose-term state out)]
        (let [[ok next-state] (unify-values compose-state raw-term built)]
          (if ok
            (advance next-state)
            (backtrack state)))
        (backtrack state))
      (if-let [list-term (univ-decompose-term state term)]
        (let [[ok next-state] (unify-values state out list-term)]
          (if ok
            (advance next-state)
            (backtrack state)))
        (backtrack state)))))

(defn term->unify-items [term]
  (if (structure-term? term)
    (seq (:args term))
    nil))

(defn enter-unify-mode [state items]
  (assoc state :unify-queue (vec items)))

(defn pop-unify-item [state]
  (let [q (:unify-queue state)]
    [(first q) (assoc state :unify-queue (vec (rest q)))]))

(defn fresh-var [state]
  (let [id (:next-var-id state)]
    [(var-term id) (update state :next-var-id inc)]))

(defn copy-term-walk [state term var-map]
  (let [term* (deref-value (:bindings state) term)]
    (cond
      (logic-var? term*)
      (if-let [fresh (get var-map (:var term*))]
        [fresh state var-map]
        (let [[fresh next-state] (fresh-var state)]
          [fresh next-state (assoc var-map (:var term*) fresh)]))

      (structure-term? term*)
      (loop [s state
             env var-map
             args (:args term*)
             out []]
        (if-let [arg (first args)]
          (let [[arg-copy s* env*] (copy-term-walk s arg env)]
            (recur s* env* (next args) (conj out arg-copy)))
          [(structure-term (:functor term*) out) s env]))

      :else
      [term* state var-map])))

(defn copy-term [state term]
  (let [[copied next-state _] (copy-term-walk state term {})]
    [copied next-state]))

(defn apply-copy-term-solution [state]
  (let [source (or (reg-get-raw state "A1") ::unbound)
        target (or (reg-get-raw state "A2") ::unbound)
        [copied copy-state] (copy-term state source)
        [ok next-state] (unify-values copy-state target copied)]
    (if ok
      (advance next-state)
      (backtrack state))))

(defn push-build-frame [state target-reg functor arity]
  (update state :build-stack conj {:target-reg target-reg
                                   :functor functor
                                   :arity arity
                                   :args []}))

(defn update-top-build-frame [state f]
  (update state :build-stack
          (fn [stk]
            (conj (pop stk) (f (peek stk))))))

(defn append-build-arg [state arg]
  (update-top-build-frame state #(update % :args conj arg)))

(defn top-build-frame-complete? [state]
  (let [frame (peek (:build-stack state))]
    (and frame (= (count (:args frame)) (:arity frame)))))

(defn a-slot? [reg]
  (and (string? reg) (.startsWith reg "A")))

(defn assign-or-unify-reg [state reg term]
  (let [current (or (reg-get-raw state reg) ::unbound)]
    (cond
      (= current ::unbound)
      [true (reg-set-raw state reg term)]

      :else
      (unify-values state current term))))

(defn finalize-top-build-frame [state]
  (let [frame (peek (:build-stack state))
        built (structure-term (:functor frame) (:args frame))
        target-reg (:target-reg frame)
        next-state (update state :build-stack pop)]
    (if (a-slot? target-reg)
      (reg-set-raw next-state target-reg built)
      (let [[ok bound-state] (assign-or-unify-reg next-state target-reg built)]
        (if ok
          bound-state
          (backtrack state))))))

(defn finalize-complete-builds [state]
  (loop [s state]
    (if (top-build-frame-complete? s)
      (let [next-state (finalize-top-build-frame s)]
        (if (= :failed (:status next-state))
          next-state
          (recur next-state)))
      s)))

(defn switch-target [state instr]
  (let [reg-val (normalize-dispatch-value
                 (:intern-context state)
                 (deref-value (:bindings state) (reg-get-raw state "A1")))
        case-map (:case-map instr)
        default-target-pc (:default-target-pc instr)
        default-fallthrough? (:default-fallthrough? instr)]
    (cond
      (contains? case-map reg-val)
      (assoc state :pc (get case-map reg-val))

      default-target-pc
      (assoc state :pc default-target-pc)

      default-fallthrough?
      (advance state)

      :else
      (backtrack state))))

(defn foreign-key [pred arity]
  (str pred "/" arity))

(defn foreign-args [state arity]
  (mapv (fn [idx]
          (denormalize-term (:intern-context state)
                            (deref-value (:bindings state)
                                         (reg-get-raw state (str "A" idx)))))
        (range 1 (inc arity))))

(defn foreign-binding-reg [idx]
  (cond
    (integer? idx) (str "A" idx)
    (string? idx) idx
    (keyword? idx) (name idx)
    :else (str idx)))

(defn apply-foreign-bindings [state bindings]
  (loop [s state
         pairs (seq bindings)]
    (if-let [[idx value] (first pairs)]
      (let [[ctx* value*] (normalize-term* (:intern-context s) value)
            s* (assoc s :intern-context ctx*)
            reg (foreign-binding-reg idx)
            current (or (reg-get-raw s* reg) ::unbound)
            [ok next-state] (unify-values s* current value*)]
        (if ok
          (recur next-state (next pairs))
          [false state]))
      [true s])))

(defn apply-foreign-result [state result]
  (cond
    (true? result)
    [true state]

    (false? result)
    [false state]

    (and (map? result) (contains? result :bindings))
    (apply-foreign-bindings state (:bindings result))

    (and (vector? result) (not-empty result))
    (apply-foreign-bindings state (into {} (map-indexed (fn [idx value] [(inc idx) value]) result)))

    :else
    [false state]))

(defn foreign-solution-results [result]
  (cond
    (and (map? result) (contains? result :solutions))
    (seq (:solutions result))

    (and (map? result) (contains? result :results))
    (seq (:results result))

    :else
    nil))

(defn push-foreign-choice-point [state base-state resume-pc results]
  (if (seq results)
    (update state :choice-points conj
            (foreign-choice-snapshot base-state resume-pc results))
    state))

(defn apply-first-foreign-solution [base-state resume-pc results]
  (loop [remaining (seq results)]
    (if-let [result (first remaining)]
      (let [[ok next-state] (apply-foreign-result base-state result)]
        (if ok
          (-> next-state
              (push-foreign-choice-point base-state resume-pc (next remaining))
              (assoc :pc resume-pc))
          (recur (next remaining))))
      (backtrack base-state))))

(defn activate-choice [state cp]
  (case (:kind cp)
    :foreign
    (if-let [results (seq (:foreign-results cp))]
      (apply-first-foreign-solution state (:pc cp) results)
      (assoc state :status :running))

    :member
    (apply-member-solution state (:pc cp) (:member-elem cp) (:member-rest cp))

    (assoc state :status :running)))

(defn execute-foreign [state instr]
  (let [key (foreign-key (:pred instr) (:arity instr))
        handler (get (:foreign-handlers state) key)]
    (if handler
      (let [result (handler (foreign-args state (:arity instr)))
            resume-pc (inc (:pc state))]
        (if-let [results (foreign-solution-results result)]
          (apply-first-foreign-solution state resume-pc results)
          (let [[ok next-state] (apply-foreign-result state result)]
            (if ok
              (advance next-state)
              (backtrack state)))))
      (backtrack state))))

(defn step [state]
  (let [instr (fetch-instr state)]
    (if-not instr
      (backtrack state)
      (case (:op instr)
        :get-constant
        (let [reg (:reg instr)
              constant (:constant instr)
              current (or (reg-get-raw state reg) ::unbound)
              current* (if (= current ::unbound) current
                         (deref-value (:bindings state) current))]
          (cond
            (= current* ::unbound)
            (-> state
                (reg-set-raw reg constant)
                advance)

            (logic-var? current*)
            (-> (bind-var state current* constant)
                advance)

            (interned-equal? current* constant)
            (advance state)

            :else
            (backtrack state)))

        :put-constant
        (-> state
            (reg-set-raw (:reg instr) (:constant instr))
            advance)

        :put-structure
        (let [arity (or (:arity instr)
                        (functor-arity (:intern-context state) (:functor instr)))]
          (-> state
              (push-build-frame (:reg instr) (:functor instr) arity)
              advance))

        :put-list
        (-> state
            (push-build-frame (:reg instr) (list-functor-term (:intern-context state)) 2)
            advance)

        :get-variable
        (let [val (reg-get-raw state (:reg instr))]
          (-> state
              (reg-set-raw (:var instr) val)
              advance))

        :get-value
        (let [left (or (reg-get-raw state (:var instr)) ::unbound)
              right (or (reg-get-raw state (:reg instr)) ::unbound)
              [ok next-state] (unify-values state left right)]
          (if ok
            (advance next-state)
            (backtrack state)))

        :get-structure
        (let [reg-val (deref-value (:bindings state)
                                   (or (reg-get-raw state (:reg instr)) ::unbound))]
          (cond
            (structure-term? reg-val)
            (if (interned-equal? (:functor reg-val) (:functor instr))
              (-> state
                  (enter-unify-mode (:args reg-val))
                  advance)
              (backtrack state))

            :else
            (backtrack state)))

        :get-list
        (let [reg-val (deref-value (:bindings state)
                                   (or (reg-get-raw state (:reg instr)) ::unbound))
              list-functor (list-functor-term (:intern-context state))]
          (cond
            (structure-term? reg-val)
            (if (interned-equal? (:functor reg-val) list-functor)
              (-> state
                  (enter-unify-mode (:args reg-val))
                  advance)
              (backtrack state))

            :else
            (backtrack state)))

        :put-variable
        (let [[fresh next-state] (fresh-var state)]
          (-> next-state
              (reg-set-raw (:var instr) fresh)
              (reg-set-raw (:reg instr) fresh)
              advance))

        :put-value
        (let [val (deref-value (:bindings state)
                               (reg-get-raw state (:var instr)))]
          (-> state
              (reg-set-raw (:reg instr) val)
              advance))

        :set-constant
        (-> state
            (append-build-arg (:constant instr))
            finalize-complete-builds
            advance)

        :set-value
        (let [val (deref-value (:bindings state)
                               (reg-get-raw state (:var instr)))]
          (-> state
              (append-build-arg val)
              finalize-complete-builds
              advance))

        :set-variable
        (let [[fresh next-state] (fresh-var state)]
          (-> next-state
              (reg-set-raw (:var instr) fresh)
              (append-build-arg fresh)
              finalize-complete-builds
              advance))

        :unify-constant
        (let [[item next-state] (pop-unify-item state)
              [ok bound-state] (unify-values next-state item (:constant instr))]
          (if ok
            (advance bound-state)
            (backtrack state)))

        :unify-variable
        (let [[item next-state] (pop-unify-item state)]
          (-> next-state
              (reg-set-raw (:var instr) item)
              advance))

        :unify-value
        (let [[item next-state] (pop-unify-item state)
              reg-val (or (reg-get-raw next-state (:var instr)) ::unbound)
              [ok bound-state] (unify-values next-state reg-val item)]
          (if ok
            (advance bound-state)
            (backtrack state)))

        :call-pc
        (-> state
            (update :stack conj (inc (:pc state)))
            (assoc :pc (:target-pc instr)))

        :execute-pc
        (assoc state :pc (:target-pc instr))

        :jump-pc
        (assoc state :pc (:target-pc instr))

        :allocate
        (-> state
            (update :env-stack conj {})
            (assoc :cut-bar (count (:choice-points state)))
            advance)

        :deallocate
        (-> state
            (update :env-stack #(if (seq %) (pop %) %))
            advance)

        :switch-on-constant
        (switch-target state instr)

        :try-me-else-pc
        (-> state
            (push-choice-point (:target-pc instr))
            advance)

        :retry-me-else-pc
        (-> state
            (push-choice-point (:target-pc instr))
            advance)

        :trust-me
        (advance state)

        :builtin-call
        (case (:pred instr)
          "=/2"
          (let [left (or (reg-get-raw state "A1") ::unbound)
                right (or (reg-get-raw state "A2") ::unbound)
                [ok next-state] (unify-values state left right)]
            (if ok
              (advance next-state)
              (backtrack state)))

          "\\=/2"
          (let [left (or (reg-get-raw state "A1") ::unbound)
                right (or (reg-get-raw state "A2") ::unbound)]
            (if (unifiable? state left right)
              (backtrack state)
              (advance state)))

          "=:=/2"
          (let [left (deref-value (:bindings state)
                                  (or (reg-get-raw state "A1") ::unbound))
                right (deref-value (:bindings state)
                                   (or (reg-get-raw state "A2") ::unbound))]
            (if (arithmetic-equal? state left right)
              (advance state)
              (backtrack state)))

          "=\\=/2"
          (let [left (deref-value (:bindings state)
                                  (or (reg-get-raw state "A1") ::unbound))
                right (deref-value (:bindings state)
                                   (or (reg-get-raw state "A2") ::unbound))]
            (if (arithmetic-not-equal? state left right)
              (advance state)
              (backtrack state)))

          "is/2"
          (let [left (deref-value (:bindings state)
                                  (or (reg-get-raw state "A1") ::unbound))
                expr (deref-value (:bindings state)
                                  (or (reg-get-raw state "A2") ::unbound))
                result (eval-arithmetic-term state expr)]
            (if (some? result)
              (let [[ok next-state] (unify-values state left result)]
                (if ok
                  (advance next-state)
                  (backtrack state)))
              (backtrack state)))

          "</2"
          (let [left (deref-value (:bindings state)
                                  (or (reg-get-raw state "A1") ::unbound))
                right (deref-value (:bindings state)
                                   (or (reg-get-raw state "A2") ::unbound))]
            (if (arithmetic-less? state left right)
              (advance state)
              (backtrack state)))

          ">/2"
          (let [left (deref-value (:bindings state)
                                  (or (reg-get-raw state "A1") ::unbound))
                right (deref-value (:bindings state)
                                   (or (reg-get-raw state "A2") ::unbound))]
            (if (arithmetic-greater? state left right)
              (advance state)
              (backtrack state)))

          "=</2"
          (let [left (deref-value (:bindings state)
                                  (or (reg-get-raw state "A1") ::unbound))
                right (deref-value (:bindings state)
                                   (or (reg-get-raw state "A2") ::unbound))]
            (if (arithmetic-less-or-equal? state left right)
              (advance state)
              (backtrack state)))

          ">=/2"
          (let [left (deref-value (:bindings state)
                                  (or (reg-get-raw state "A1") ::unbound))
                right (deref-value (:bindings state)
                                   (or (reg-get-raw state "A2") ::unbound))]
            (if (arithmetic-greater-or-equal? state left right)
              (advance state)
              (backtrack state)))

          "true/0"
          (advance state)

          "fail/0"
          (backtrack state)

          "atom/1"
          (let [value (deref-value (:bindings state)
                                   (or (reg-get-raw state "A1") ::unbound))]
            (if (atom-term? value)
              (advance state)
              (backtrack state)))

          "integer/1"
          (let [value (deref-value (:bindings state)
                                   (or (reg-get-raw state "A1") ::unbound))]
            (if (integer? value)
              (advance state)
              (backtrack state)))

          "number/1"
          (let [value (deref-value (:bindings state)
                                   (or (reg-get-raw state "A1") ::unbound))]
            (if (number? value)
              (advance state)
              (backtrack state)))

          "atomic/1"
          (let [value (deref-value (:bindings state)
                                   (or (reg-get-raw state "A1") ::unbound))]
            (if (or (atom-term? value) (number? value))
              (advance state)
              (backtrack state)))

          "nonvar/1"
          (let [value (deref-value (:bindings state)
                                   (or (reg-get-raw state "A1") ::unbound))]
            (if (and (not= value ::unbound) (not (logic-var? value)))
              (advance state)
              (backtrack state)))

          "var/1"
          (let [value (deref-value (:bindings state)
                                   (or (reg-get-raw state "A1") ::unbound))]
            (if (or (= value ::unbound) (logic-var? value))
              (advance state)
              (backtrack state)))

          "compound/1"
          (let [value (deref-value (:bindings state)
                                   (or (reg-get-raw state "A1") ::unbound))]
            (if (structure-term? value)
              (advance state)
              (backtrack state)))

          "callable/1"
          (let [value (deref-value (:bindings state)
                                   (or (reg-get-raw state "A1") ::unbound))]
            (if (or (atom-term? value) (structure-term? value))
              (advance state)
              (backtrack state)))

          "float/1"
          (let [value (deref-value (:bindings state)
                                   (or (reg-get-raw state "A1") ::unbound))]
            (if (float? value)
              (advance state)
              (backtrack state)))

          "is_list/1"
          (let [value (deref-value (:bindings state)
                                   (or (reg-get-raw state "A1") ::unbound))]
            (if (proper-list-term? state value)
              (advance state)
              (backtrack state)))

          "length/2"
          (let [list-value (deref-value (:bindings state)
                                        (or (reg-get-raw state "A1") ::unbound))
                len (proper-list-length state list-value)
                out (deref-value (:bindings state)
                                 (or (reg-get-raw state "A2") ::unbound))]
            (if (some? len)
              (let [[ok next-state] (unify-values state out len)]
                (if ok
                  (advance next-state)
                  (backtrack state)))
              (backtrack state)))

          "member/2"
          (let [elem (deref-value (:bindings state)
                                  (or (reg-get-raw state "A1") ::unbound))
                list-value (deref-value (:bindings state)
                                        (or (reg-get-raw state "A2") ::unbound))]
            (apply-member-solution state (inc (:pc state)) elem list-value))

          "append/3"
          (let [left (deref-value (:bindings state)
                                  (or (reg-get-raw state "A1") ::unbound))
                right (deref-value (:bindings state)
                                   (or (reg-get-raw state "A2") ::unbound))
                out (deref-value (:bindings state)
                                 (or (reg-get-raw state "A3") ::unbound))]
            (apply-append-solution state (inc (:pc state)) left right out))

          "copy_term/2"
          (apply-copy-term-solution state)

          "functor/3"
          (apply-functor-solution state)

          "arg/3"
          (apply-arg-solution state)

          "=../2"
          (apply-univ-solution state)

          "ground/1"
          (let [value (deref-value (:bindings state)
                                   (or (reg-get-raw state "A1") ::unbound))]
            (if (ground-term? state value)
              (advance state)
              (backtrack state)))

          "!/0"
          (-> state
              (update :choice-points #(vec (take (:cut-bar state) %)))
              advance)

          (backtrack state))

        :call-foreign
        (execute-foreign state instr)

        :cut-ite
        (-> state
            (update :choice-points #(if (seq %) (pop %) %))
            advance)

        :proceed
        (if (seq (:stack state))
          (let [[ret-pc next-state] (pop-call-stack state)]
            (assoc next-state :pc ret-pc))
          (succeed-state state))

        (backtrack state)))))

(defn run-wam [state]
  (loop [s state]
    (case (:status s)
      :succeeded true
      :failed false
      (recur (step s)))))

(defn run-wam-predicate
  ([code labels start-pc regs]
   (run-wam-predicate code labels start-pc regs {} nil))
  ([code labels start-pc regs foreign-handlers]
   (run-wam-predicate code labels start-pc regs foreign-handlers nil))
  ([code labels start-pc regs foreign-handlers intern-context]
   (run-wam (new-state code labels start-pc regs foreign-handlers intern-context))))
