// ============================================================
// WamRuntime — stepping interpreter (Layer B/C bridge)
// ============================================================

object WamRuntime {

  // ----------------------------------------------------------
  // Register encoding — mirrors Haskell target's reg_to_int
  // ----------------------------------------------------------
  val REG_ARRAY_SIZE = 300

  def regIndex(name: String): Int = {
    if (name.isEmpty) 0
    else name.head match {
      case 'A' => name.tail.toIntOption.getOrElse(0)
      case 'X' => name.tail.toIntOption.getOrElse(0) + 100
      case 'Y' => name.tail.toIntOption.getOrElse(0) + 200
      case _   => 0
    }
  }

  def isYReg(idx: Int): Boolean = idx >= 201 && idx <= 299

  // ----------------------------------------------------------
  // Instruction resolution — one pass, symbolic → PC
  // ----------------------------------------------------------

  def resolveInstructions(raw: Array[Instruction], labels: Map[String, Int]): Array[Instruction] =
    raw.map {
      case Call(pred, arity)      => labels.get(s"$pred/$arity").map(CallPc(_, arity)).getOrElse(Call(pred, arity))
      case Execute(pred, arity)   => labels.get(s"$pred/$arity").map(ExecutePc(_)).getOrElse(Execute(pred, arity))
      case Jump(lbl)              => labels.get(lbl).map(JumpPc(_)).getOrElse(Jump(lbl))
      case TryMeElse(lbl)        => labels.get(lbl).map(TryMeElsePc(_)).getOrElse(TryMeElse(lbl))
      case RetryMeElse(lbl)      => labels.get(lbl).map(RetryMeElsePc(_)).getOrElse(RetryMeElse(lbl))
      case SwitchOnConstant(cases) =>
        val resolved = cases.map { sc =>
          if (sc.label == "default") sc  // default = fallthrough (targetPc stays -1) or resolved below
          else labels.get(sc.label).map(pc => sc.copy(targetPc = pc)).getOrElse(sc)
        }
        SwitchOnConstant(resolved)
      case other => other
    }

  // ----------------------------------------------------------
  // State construction
  // ----------------------------------------------------------

  def newState(startPc: Int, argRegs: Array[WamTerm]): WamState = {
    val regs = new Array[WamTerm](REG_ARRAY_SIZE)
    argRegs.zipWithIndex.foreach { case (v, i) => regs(i + 1) = v }
    new WamState(
      regs       = regs,
      envStack   = Nil,
      choicePoints = Nil,
      trail      = Nil,
      callStack  = Nil,
      unifyQueue = Nil,
      buildStack = Nil,
      bindings   = mutable.Map.empty,
      pc         = startPc,
      nextVarId  = 0,
      cutBar     = 0,
      status     = Running
    )
  }

  // ----------------------------------------------------------
  // Term operations
  // ----------------------------------------------------------

  def deref(bindings: mutable.Map[Int, WamTerm], v: WamTerm): WamTerm = v match {
    case r @ Ref(id) => bindings.get(id).map(deref(bindings, _)).getOrElse(r)
    case other       => other
  }

  def getReg(s: WamState, idx: Int): WamTerm = {
    if (isYReg(idx)) {
      val slot = idx - 200
      s.envStack.headOption.flatMap(f => Option(f.savedRegs(slot))).getOrElse(null)
    } else {
      s.regs(idx)
    }
  }

  def setReg(s: WamState, idx: Int, value: WamTerm): Unit = {
    if (isYReg(idx)) {
      val slot = idx - 200
      s.envStack.headOption.foreach(_.savedRegs(slot) = value)
      s.regs(idx) = value // keep live copy in sync
    } else {
      s.regs(idx) = value
    }
  }

  def bindVar(s: WamState, ref: Ref, value: WamTerm): Unit = {
    val old = s.bindings.get(ref.id)
    s.trail = TrailEntry(ref.id, old) :: s.trail
    s.bindings(ref.id) = value
  }

  def unwindTrail(s: WamState, targetLen: Int): Unit = {
    val toUndo = s.trail.take(s.trail.length - targetLen)
    toUndo.foreach { e =>
      e.oldValue match {
        case Some(v) => s.bindings(e.varId) = v
        case None    => s.bindings.remove(e.varId)
      }
    }
    s.trail = s.trail.drop(toUndo.length)
  }

  def unify(s: WamState, a: WamTerm, b: WamTerm): Boolean = {
    val da = deref(s.bindings, a)
    val db = deref(s.bindings, b)
    (da, db) match {
      case _ if da == db => true
      case (r @ Ref(_), _) => bindVar(s, r, db); true
      case (_, r @ Ref(_)) => bindVar(s, r, da); true
      case (Struct(f1, a1, args1), Struct(f2, a2, args2))
          if f1 == f2 && a1 == a2 =>
        args1.zip(args2).forall { case (x, y) => unify(s, x, y) }
      case _ => false
    }
  }

  def freshVar(s: WamState): Ref = {
    val id = s.nextVarId
    s.nextVarId += 1
    Ref(id)
  }

  // ----------------------------------------------------------
  // Choice point management
  // ----------------------------------------------------------

  def snapshotRegs(s: WamState): Array[WamTerm] = s.regs.clone()

  def pushChoicePoint(s: WamState, targetPc: Int): Unit = {
    val cp = ChoicePoint(
      pc        = targetPc,
      regs      = snapshotRegs(s),
      envStack  = s.envStack,
      callStack = s.callStack,
      trailLen  = s.trail.length,
      cutBar    = s.cutBar,
      nextVarId = s.nextVarId,
      kind      = WamCP
    )
    s.choicePoints = cp :: s.choicePoints
  }

  def backtrack(s: WamState): Unit = s.choicePoints match {
    case Nil =>
      s.status = Failed
    case cp :: rest =>
      unwindTrail(s, cp.trailLen)
      System.arraycopy(cp.regs, 0, s.regs, 0, REG_ARRAY_SIZE)
      s.envStack   = cp.envStack
      s.callStack  = cp.callStack
      s.cutBar     = cp.cutBar
      s.nextVarId  = cp.nextVarId
      s.unifyQueue = Nil
      s.buildStack = Nil
      s.pc         = cp.pc
      s.status     = Running
      cp.kind match {
        case ForeignCP(Nil) =>
          s.choicePoints = rest
          backtrack(s)
        case ForeignCP(sol +: remaining) =>
          s.choicePoints = cp.copy(kind = ForeignCP(remaining)) :: rest
          applyBindings(s, sol)
        case WamCP =>
          s.choicePoints = rest
      }
  }

  def applyBindings(s: WamState, binds: Map[Int, WamTerm]): Unit =
    binds.foreach { case (reg, v) =>
      val current = deref(s.bindings, s.regs(reg))
      current match {
        case r @ Ref(_) => bindVar(s, r, v)
        case existing   => if (!unify(s, existing, v)) s.status = Failed
      }
    }

  // ----------------------------------------------------------
  // Structure/list build stack helpers
  // ----------------------------------------------------------

  def appendBuildArg(s: WamState, arg: WamTerm): Unit = s.buildStack match {
    case Nil => // ignore (shouldn't happen in correct code)
    case top :: rest =>
      val updated = top.copy(args = top.args :+ arg)
      s.buildStack = updated :: rest
      if (updated.args.length == updated.sArity)
        finalizeBuild(s)
  }

  def finalizeBuild(s: WamState): Unit = s.buildStack match {
    case Nil =>
    case top :: rest =>
      s.buildStack = rest
      val built = Struct(top.functorId, top.sArity, top.args.toArray)
      val current = s.regs(top.targetReg)
      val ok = if (current == null) { setReg(s, top.targetReg, built); true }
               else unify(s, deref(s.bindings, current), built)
      if (!ok) backtrack(s)
      else if (s.buildStack.nonEmpty && s.buildStack.head.args.length == s.buildStack.head.sArity)
        finalizeBuild(s)
  }

  // ----------------------------------------------------------
  // Foreign predicate execution
  // ----------------------------------------------------------

  def foreignKey(pred: String, arity: Int): String = s"$pred/$arity"

  def foreignArgs(s: WamState, arity: Int): Array[WamTerm] =
    (1 to arity).map(i => deref(s.bindings, s.regs(i))).toArray

  def executeForeign(s: WamState, program: WamProgram, pred: String, arity: Int): Unit = {
    val key = foreignKey(pred, arity)
    program.foreignHandlers.get(key) match {
      case None =>
        backtrack(s)
      case Some(handler) =>
        val args   = foreignArgs(s, arity)
        val result = handler.apply(args)
        val resumePc = s.pc + 1
        result match {
          case ForeignFail =>
            backtrack(s)
          case ForeignSucceed =>
            s.pc = resumePc
          case ForeignBindings(binds) =>
            applyBindings(s, binds)
            if (s.status == Running) s.pc = resumePc
          case ForeignMulti(Nil) =>
            backtrack(s)
          case ForeignMulti(sol +: rest) =>
            if (rest.nonEmpty) {
              val cp = ChoicePoint(
                pc        = resumePc,
                regs      = snapshotRegs(s),
                envStack  = s.envStack,
                callStack = s.callStack,
                trailLen  = s.trail.length,
                cutBar    = s.cutBar,
                nextVarId = s.nextVarId,
                kind      = ForeignCP(rest)
              )
              s.choicePoints = cp :: s.choicePoints
            }
            applyBindings(s, sol)
            if (s.status == Running) s.pc = resumePc
        }
    }
  }

  // ----------------------------------------------------------
  // First-argument indexing
  // ----------------------------------------------------------

  def switchTarget(s: WamState, cases: Array[SwitchCase]): Unit = {
    val key = deref(s.bindings, s.regs(1))
    // Build lookup map (default = label "default")
    val defaultPc = cases.find(_.label == "default").map(_.targetPc).getOrElse(-1)
    val defaultFallthrough = cases.exists(c => c.label == "default" && c.targetPc == -1)
    val caseMap = cases.filter(_.label != "default").map(c => c.value -> c.targetPc).toMap
    caseMap.get(key) match {
      case Some(pc) => s.pc = pc
      case None if defaultPc >= 0 => s.pc = defaultPc
      case None if defaultFallthrough => s.pc += 1
      case _ => backtrack(s)
    }
  }

  // ----------------------------------------------------------
  // Main step function — mutates state in place
  // ----------------------------------------------------------

  def step(s: WamState, program: WamProgram): Unit = {
    val instr = program.instructions(s.pc)
    instr match {

      // --- Control ---

      case Proceed =>
        s.callStack match {
          case Nil       => s.status = Succeeded
          case ret :: rest =>
            s.callStack = rest
            s.pc = ret
        }

      case CallPc(target, _) =>
        s.callStack = (s.pc + 1) :: s.callStack
        s.pc = target

      case ExecutePc(target) =>
        s.pc = target

      case JumpPc(target) =>
        s.pc = target

      case Call(pred, arity) =>
        // Unresolved — look up in dispatch table
        program.dispatch.get(s"$pred/$arity") match {
          case Some(pc) =>
            s.callStack = (s.pc + 1) :: s.callStack
            s.pc = pc
          case None =>
            backtrack(s)
        }

      case Execute(pred, arity) =>
        program.dispatch.get(s"$pred/$arity") match {
          case Some(pc) => s.pc = pc
          case None     => backtrack(s)
        }

      case Jump(lbl) =>
        program.labels.get(lbl) match {
          case Some(pc) => s.pc = pc
          case None     => backtrack(s)
        }

      // --- Environment ---

      case Allocate =>
        val frame = EnvFrame(new Array[WamTerm](100)) // Y1-Y99
        // Copy current Y-reg values into frame
        for (i <- 201 until 300 if s.regs(i) != null)
          frame.savedRegs(i - 200) = s.regs(i)
        s.envStack = frame :: s.envStack
        s.cutBar = s.choicePoints.length
        s.pc += 1

      case Deallocate =>
        s.envStack = s.envStack.drop(1)
        s.pc += 1

      // --- Register: get ---

      case GetConstant(value, reg) =>
        val current = deref(s.bindings, s.regs(reg))
        val ok = if (current == null) { s.regs(reg) = value; true }
                 else unify(s, current, value)
        if (ok) s.pc += 1 else backtrack(s)

      case GetVariable(varReg, argReg) =>
        setReg(s, varReg, s.regs(argReg))
        s.pc += 1

      case GetValue(varReg, argReg) =>
        val ok = unify(s, deref(s.bindings, getReg(s, varReg)), deref(s.bindings, s.regs(argReg)))
        if (ok) s.pc += 1 else backtrack(s)

      // --- Register: put ---

      case PutConstant(value, reg) =>
        setReg(s, reg, value)
        s.pc += 1

      case PutVariable(varReg, argReg) =>
        val v = freshVar(s)
        setReg(s, varReg, v)
        s.regs(argReg) = v
        s.pc += 1

      case PutValue(varReg, argReg) =>
        s.regs(argReg) = deref(s.bindings, getReg(s, varReg))
        s.pc += 1

      // --- Structure / list ---

      case PutStructure(functorId, reg, sArity) =>
        s.buildStack = BuildFrame(reg, functorId, sArity, Nil) :: s.buildStack
        s.pc += 1

      case PutList(reg) =>
        s.buildStack = BuildFrame(reg, -1 /* [|]/2 */, 2, Nil) :: s.buildStack
        s.pc += 1

      case SetVariable(varReg) =>
        val v = freshVar(s)
        setReg(s, varReg, v)
        appendBuildArg(s, v)
        if (s.status == Running) s.pc += 1

      case SetValue(varReg) =>
        appendBuildArg(s, deref(s.bindings, getReg(s, varReg)))
        if (s.status == Running) s.pc += 1

      case SetConstant(value) =>
        appendBuildArg(s, value)
        if (s.status == Running) s.pc += 1

      case GetStructure(functorId, reg) =>
        val v = deref(s.bindings, s.regs(reg))
        v match {
          case Struct(f, _, args) if f == functorId =>
            s.unifyQueue = args.toList
            s.pc += 1
          case _ => backtrack(s)
        }

      case GetList(reg) =>
        val v = deref(s.bindings, s.regs(reg))
        v match {
          case Struct(-1, 2, args) => // [|]/2 sentinel
            s.unifyQueue = args.toList
            s.pc += 1
          case _ => backtrack(s)
        }

      case UnifyVariable(varReg) =>
        s.unifyQueue match {
          case Nil => backtrack(s)
          case item :: rest =>
            setReg(s, varReg, item)
            s.unifyQueue = rest
            s.pc += 1
        }

      case UnifyValue(varReg) =>
        s.unifyQueue match {
          case Nil => backtrack(s)
          case item :: rest =>
            val ok = unify(s, deref(s.bindings, getReg(s, varReg)), item)
            s.unifyQueue = rest
            if (ok) s.pc += 1 else backtrack(s)
        }

      case UnifyConstant(value) =>
        s.unifyQueue match {
          case Nil => backtrack(s)
          case item :: rest =>
            val ok = unify(s, deref(s.bindings, item), value)
            s.unifyQueue = rest
            if (ok) s.pc += 1 else backtrack(s)
        }

      // --- Choice ---

      case TryMeElsePc(target) =>
        pushChoicePoint(s, target)
        s.pc += 1

      case RetryMeElsePc(target) =>
        pushChoicePoint(s, target)
        s.pc += 1

      case TrustMe =>
        s.pc += 1

      case TryMeElse(lbl) =>
        program.labels.get(lbl).foreach(pushChoicePoint(s, _))
        s.pc += 1

      case RetryMeElse(lbl) =>
        program.labels.get(lbl).foreach(pushChoicePoint(s, _))
        s.pc += 1

      // --- Indexing ---

      case SwitchOnConstant(cases) =>
        switchTarget(s, cases)

      // --- Builtins ---

      case BuiltinCall(pred, _) => pred match {
        case "=/2" =>
          val a = deref(s.bindings, s.regs(1))
          val b = deref(s.bindings, s.regs(2))
          val ok = unify(s, a, b)
          if (ok) s.pc += 1 else backtrack(s)
        case "true/0" =>
          s.pc += 1
        case "!/0" =>
          s.choicePoints = s.choicePoints.drop(s.choicePoints.length - s.cutBar)
          s.pc += 1
        case _ =>
          backtrack(s)
      }

      // --- Foreign ---

      case CallForeign(pred, arity) =>
        executeForeign(s, program, pred, arity)

      // --- If-then-else soft cut ---

      case CutIte =>
        if (s.choicePoints.nonEmpty)
          s.choicePoints = s.choicePoints.tail
        s.pc += 1

      // --- Fallback ---

      case Raw(_) =>
        backtrack(s) // unknown instruction = fail

      case _ =>
        backtrack(s)
    }
  }

  // ----------------------------------------------------------
  // Run loop
  // ----------------------------------------------------------

  def run(s: WamState, program: WamProgram): Boolean = {
    while (s.status == Running)
      step(s, program)
    s.status == Succeeded
  }

  def runPredicate(program: WamProgram, startPc: Int, argRegs: Array[WamTerm]): Boolean = {
    val s = newState(startPc, argRegs)
    run(s, program)
  }
}
