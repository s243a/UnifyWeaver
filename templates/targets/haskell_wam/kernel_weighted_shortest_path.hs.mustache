-- | Finite nonnegative Dijkstra for weighted_shortest_path3
-- (docs/design/WAM_WEIGHTED_SHORTEST_PATH3_CONTRACT.md).
-- Auto-generated from kernel detection. Edge predicate: {{edge_pred}}.
--
-- Emit exactly one (Target, Double) pair per reachable non-Source
-- target at minimum path cost. Source is never emitted (even via
-- self-loop / cycle). Integral sums remain Double floats.
--
-- Atoms are interned at the FFI boundary (Int IDs in the IntMap key).
-- A reachable invalid weight (NaN / Inf / negative) fails the complete
-- call via `error` — callers treat absence of a successful stream as
-- failure. Non-atom destinations are already excluded by Int keys.
nativeKernel_weighted_shortest_path
  :: IM.IntMap [(Int, Double)] -> Int -> [(Int, Double)]
nativeKernel_weighted_shortest_path edges source =
  -- Priority queue as a Map keyed by (cost, node) pair for min-ordering.
  -- Set gives us O(log n) extract-min via Set.minView.
  let initQueue = Set.singleton (0.0 :: Double, source)
      initDist  = IM.singleton source (0.0 :: Double)
  in go initQueue initDist
  where
    go queue dist =
      case Set.minView queue of
        Nothing ->
          [ (n, c) | (n, c) <- IM.toList dist, n /= source ]
        Just ((cost, node), queue') ->
          -- Skip stale entries (we may have a better cost for this node)
          let bestSoFar = IM.findWithDefault (1/0) node dist
          in if cost > bestSoFar
               then go queue' dist
               else
                 -- Relax outgoing edges; fail hard on invalid reachable weight
                 let neighbors = IM.findWithDefault [] node edges
                     step (q, d) (nxt, w)
                       | isNaN w || isInfinite w || w < 0 =
                           error "wsp3: reachable invalid weighted edge row"
                       | otherwise =
                           let newCost = cost + w
                               prev = IM.findWithDefault (1/0) nxt d
                           in if newCost < prev
                                then (Set.insert (newCost, nxt) q, IM.insert nxt newCost d)
                                else (q, d)
                     (queue'', dist') = foldl' step (queue', dist) neighbors
                 in go queue'' dist'
