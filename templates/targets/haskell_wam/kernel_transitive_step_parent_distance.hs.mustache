-- | Native BFS with correlated (step, parent) pair sets for binary edges.
-- Auto-generated from kernel detection. Edge predicate: {{edge_pred}}.
--
-- Contract: shortest-positive correlated step/parent
-- (docs/design/WAM_TRANSITIVE_STEP_PARENT_DISTANCE5_CONTRACT.md).
-- Given a source node, returns a stream of (target, step, parent, distance)
-- quadruples: every correlated first-hop / final-predecessor pair of each
-- reachable target on a shortest positive path. Equal-shortest pairs are
-- all emitted; never an independent Step×Parent cross-product.
-- Dist tracks nodes discovered via an edge (do not seed Source).
--
-- Exercises the 4-output FFIStreamRetry path.
nativeKernel_transitive_step_parent_distance
  :: EdgeLookup -> Int -> [(Int, Int, Int, Int)]
nativeKernel_transitive_step_parent_distance edges source =
  let (distMap, pairMap) = go [(source, 0)] IM.empty IM.empty
  in [ (t, step, parent, d)
     | (t, d) <- IM.toAscList distMap
     , (step, parent) <- IM.findWithDefault [] t pairMap
     ]
  where
    go [] dist pairs = (dist, pairs)
    go ((node, d):queue) dist pairs =
      let nd = d + 1
          candPairs n
            | node == source = [(n, source)]
            | otherwise =
                let steps = map fst (IM.findWithDefault [] node pairs)
                in [(s, node) | s <- nubOrd steps]
          step (qAcc, distAcc, pairAcc) n =
            let cands = candPairs n
            in case IM.lookup n distAcc of
              Nothing ->
                ( qAcc ++ [(n, nd)]
                , IM.insert n nd distAcc
                , IM.insert n (nubOrd cands) pairAcc
                )
              Just d0
                | d0 == nd ->
                    ( qAcc
                    , distAcc
                    , IM.insert n (nubOrd (IM.findWithDefault [] n pairAcc ++ cands)) pairAcc
                    )
                | otherwise -> (qAcc, distAcc, pairAcc)
          (queue', dist', pairs') =
            foldl step (queue, dist, pairs) (edges node)
      in go queue' dist' pairs'
    nubOrd = map head . group . sort
