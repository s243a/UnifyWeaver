-- | Native BFS with shortest-parent sets for binary edge relations.
-- Auto-generated from kernel detection. Edge predicate: {{edge_pred}}.
--
-- Contract: shortest-positive parents
-- (docs/design/WAM_TRANSITIVE_PARENT_DISTANCE4_CONTRACT.md).
-- Given a source node, returns a stream of (target, parent, distance)
-- triples: every immediate predecessor of each reachable target on a
-- shortest positive path. Equal-shortest parents are all emitted.
-- Source appears only via self-loop / nonempty cycle — never distance 0.
-- Visited/dist tracks nodes discovered via an edge (do not seed Source).
--
-- Exercises the 3-output FFIStreamRetry path. Atoms (target, parent) are
-- interned; distance is a plain Int. Organization: Mustache kept
-- (non-trivial BFS + parent-set body).
nativeKernel_transitive_parent_distance
  :: EdgeLookup -> Int -> [(Int, Int, Int)]
nativeKernel_transitive_parent_distance edges source =
  let (distMap, parentMap) = go [(source, 0)] IM.empty IM.empty
  in [ (t, p, d)
     | (t, d) <- IM.toAscList distMap
     , p <- IS.toAscList (IM.findWithDefault IS.empty t parentMap)
     ]
  where
    go [] dist parents = (dist, parents)
    go ((node, d):queue) dist parents =
      let nd = d + 1
          step (qAcc, distAcc, parAcc) n =
            case IM.lookup n distAcc of
              Nothing ->
                ( qAcc ++ [(n, nd)]
                , IM.insert n nd distAcc
                , IM.insert n (IS.singleton node) parAcc
                )
              Just d0
                | d0 == nd ->
                    ( qAcc
                    , distAcc
                    , IM.adjust (IS.insert node) n parAcc
                    )
                | otherwise -> (qAcc, distAcc, parAcc)
          (queue', dist', parents') =
            foldl step (queue, dist, parents) (edges node)
      in go queue' dist' parents'
