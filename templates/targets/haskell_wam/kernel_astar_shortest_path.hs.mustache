-- | Correctness-safe A* / Dijkstra-minimum for astar_shortest_path4
-- (docs/design/WAM_ASTAR_SHORTEST_PATH4_CONTRACT.md).
-- Auto-generated from kernel detection. Edge predicate: {{edge_pred}}.
-- Heuristic: {{direct_dist_pred}}.
--
-- Final Double is always the finite Dijkstra minimum from source to
-- target. Dim and heuristic may only affect scheduling. Missing h = 0.0.
-- Source=Target → [0.0]. Malformed reachable edge or relevant heuristic
-- rows fail the call via empty result (no exception).
nativeKernel_astar_shortest_path
  :: IM.IntMap [(Int, Double)]   -- ^ weight edges
  -> IM.IntMap [(Int, Double)]   -- ^ heuristic oracle (direct_dist_pred)
  -> Int                         -- ^ source
  -> Int                         -- ^ target
  -> Int                         -- ^ dimensionality (must be > 0)
  -> [Double]
nativeKernel_astar_shortest_path edges heur source target dim
  | dim <= 0 = []
  | source == target = [0.0]
  | otherwise =
      case sched 0.0 source of
        Left _ -> []
        Right f0 ->
          case go (Set.singleton (0.0 :: Double, f0, source))
                  (IM.singleton source 0.0) of
            Left _ -> []
            Right Nothing -> []
            Right (Just c) -> [c]
  where
    -- Relevant heuristic: min valid (node,target) weight; missing → 0.
    -- Malformed relevant row → Left ().
    heuristic node =
      case IM.lookup node heur of
        Nothing -> Right 0.0
        Just es ->
          let hs = [ h | (t, h) <- es, t == target ]
          in case hs of
               [] -> Right 0.0
               _  ->
                 if any (\h -> isNaN h || isInfinite h || h < 0) hs
                   then Left ()
                   else Right (minimum hs)

    sched g node = do
      h <- heuristic node
      let d = fromIntegral dim :: Double
      pure (g ** d + h ** d)

    go queue gScores =
      case Set.minView queue of
        Nothing -> Right Nothing
        Just ((gCost, _f, node), queue') ->
          let best = IM.findWithDefault (1/0) node gScores
          in if gCost > best
               then go queue' gScores
               else if node == target
                      then Right (Just gCost)
                      else
                        let neighbors = IM.findWithDefault [] node edges
                        in case foldl' (relax gCost) (Right (queue', gScores)) neighbors of
                             Left () -> Left ()
                             Right (q2, d2) -> go q2 d2

    relax _ (Left ()) _ = Left ()
    relax gCost (Right (q, d)) (nxt, w)
      | isNaN w || isInfinite w || w < 0 = Left ()
      | otherwise =
          let newG = gCost + w
              prev = IM.findWithDefault (1/0) nxt d
          in if newG < prev
               then case sched newG nxt of
                      Left () -> Left ()
                      Right f ->
                        Right (Set.insert (newG, f, nxt) q, IM.insert nxt newG d)
               else Right (q, d)
