    (i64.and (i64.shr_u (local.get $op1i) (i64.const 16)) (i64.const 0xFF))))
  (local.set $n_addr (call $deref_reg_addr (local.get $n_idx)))
  (local.set $t_addr (call $deref_reg_addr (local.get $t_idx)))
  (if (i32.and
