; Fetch instruction at current PC
define %Instruction* @wam_fetch(%WamState* %vm) {
entry:
  %pc = call i32 @wam_get_pc(%WamState* %vm)
  %cl_ptr = getelementptr %WamState, %WamState* %vm, i32 0, i32 16
  %cl = load i32, i32* %cl_ptr
