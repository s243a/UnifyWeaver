wfa.advance:
  %wfa.off_next = add i64 %wfa.off, %wfa.n
  %wfa.done = icmp eq i64 %wfa.off_next, %wfa.len
  br i1 %wfa.done, label %wfa.success, label %wfa.loop
wfa.close_fail:
  call i32 @close(i32 %wfa.fd)
  ret i1 false
wfa.success:
  call i32 @close(i32 %wfa.fd)
  ret i1 true

