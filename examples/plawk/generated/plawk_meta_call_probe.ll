nml.fail:
  ret i1 false
nml.range:
  %nml.lo = extractvalue %Value %nml.a1, 1
  %nml.hi = extractvalue %Value %nml.a2, 1
  %nml.diff = sub i64 %nml.hi, %nml.lo
  %nml.count = add i64 %nml.diff, 1
  %nml.empty = icmp sle i64 %nml.count, 0
