  call void @wam_push_foreign_choice_point(%WamState* %vm,
      i8* %bet.arr_i8, i32 %bet.count, i32 2, i32 %bet.return_pc)
  ret i1 true

builtin_atom_concat:
  ; M29: atom_concat(A1, A2, A3) -- forward mode only.
