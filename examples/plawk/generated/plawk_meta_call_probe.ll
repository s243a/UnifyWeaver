pkv.bind:
  %pkv.raw2 = call %Value @wam_get_reg(%WamState* %vm, i32 1)
  %pkv.uk = call i1 @wam_unify_value(%WamState* %vm, %Value %pkv.raw2, %Value %pkv.k_final)
