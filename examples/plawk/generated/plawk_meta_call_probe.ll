  %rfta.arena = call i8* @wam_arena_alloc(i64 %rfta.bufsize)
  %rfta.empty = icmp eq i64 %rfta.size, 0
  br i1 %rfta.empty, label %rfta.finalize, label %rfta.loop
rfta.loop:
