  %bet.diff = sub i64 %bet.hi, %bet.lo
  %bet.count64 = add i64 %bet.diff, 1
  %bet.empty = icmp sle i64 %bet.count64, 0
  br i1 %bet.empty, label %bet.fail, label %bet.size_check
bet.size_check:
