  %pkv.r_neither_cmp = and i1 %pkv.r_k_cmp, %pkv.r_v_cmp
  br i1 %pkv.r_both_cmp, label %pkv.r_count_step, label %pkv.r_count_check_end
pkv.r_count_check_end:
