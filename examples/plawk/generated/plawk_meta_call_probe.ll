pkv.r_alloc:
  %pkv.r_cnt64 = sext i32 %pkv.r_cnt to i64
  %pkv.r_arr_bytes = shl i64 %pkv.r_cnt64, 4
  %pkv.r_arr_mem = call i8* @wam_arena_alloc(i64 %pkv.r_arr_bytes)
  %pkv.r_arr = bitcast i8* %pkv.r_arr_mem to %Value*
