  %rfta.off_next = add i64 %rfta.off, %rfta.n
  %rfta.done = icmp eq i64 %rfta.off_next, %rfta.size
  br i1 %rfta.done, label %rfta.finalize, label %rfta.loop
rfta.close_fail:
  call i32 @close(i32 %rfta.fd)
  ret i1 false
rfta.finalize:
  call i32 @close(i32 %rfta.fd)
