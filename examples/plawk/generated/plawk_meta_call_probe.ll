  %pkv.uv = call i1 @wam_unify_value(%WamState* %vm, %Value %pkv.raw3, %Value %pkv.vb_acc)
  ret i1 %pkv.uv

pkv.r_init:
  ; Reverse: A1 unbound. Walk Keys + Values in parallel, requiring
  ; equal length; build pair_arr of -/2 compounds; cons-chain it;
  ; unify A1.
