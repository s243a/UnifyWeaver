  call i32 @close(i32 %cpf.dst_fd)
  ret i1 true
cpf.close_both_fail:
  call i32 @close(i32 %cpf.src_fd)
  call i32 @close(i32 %cpf.dst_fd)
  ret i1 false

builtin_read_file_to_atom:
  ; M129: read_file_to_atom(+Path, -Atom) -- reads the entire file
